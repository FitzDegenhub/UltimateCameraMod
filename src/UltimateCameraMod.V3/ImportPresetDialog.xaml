<Window x:Class="UltimateCameraMod.V3.ImportPresetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Preset" Width="420" Height="300" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource BgDarkBrush}">
    <StackPanel Margin="24">
        <TextBlock Text="Choose an import source" FontSize="14" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

        <Button Content="Mod Manager Package (folder)" Style="{StaticResource AccentButton}"
                Height="38" FontSize="12" Click="OnImportModPackage" Margin="0,0,0,8"
                ToolTip="Select a folder containing manifest.json — imports name, author, and camera XML automatically"/>

        <Button Content="Camera XML File (.xml)" Style="{StaticResource SubtleButton}"
                Height="38" FontSize="12" Click="OnImportXml" Margin="0,0,0,8"
                ToolTip="Select a playercamerapreset.xml file directly"/>

        <Button Content="PAZ Archive (.paz)" Style="{StaticResource SubtleButton}"
                Height="38" FontSize="12" Click="OnImportPaz" Margin="0,0,0,8"
                ToolTip="Select a 0.paz file — UCM will extract the camera XML from it"/>

        <TextBlock Text="Imports are saved in the import_presets folder next to this app and listed under Imported in the sidebar."
                   FontSize="10" Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap"
                   Margin="0,12,0,0"/>

        <Button Content="Cancel" Style="{StaticResource SubtleButton}"
                Height="32" FontSize="11" Width="90" HorizontalAlignment="Right"
                Click="OnCancel" Margin="0,12,0,0"/>
    </StackPanel>
</Window>
