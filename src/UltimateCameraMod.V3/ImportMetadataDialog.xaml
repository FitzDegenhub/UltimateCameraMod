<Window x:Class="UltimateCameraMod.V3.ImportMetadataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import — Preset Details" Width="480" Height="420" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource BgDarkBrush}">
    <StackPanel Margin="24">
        <TextBlock Text="Preset details" FontSize="14" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
        <TextBlock x:Name="SourceHintLabel" FontSize="10"
                   Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <TextBlock Text="Name *" FontSize="11" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox" Height="32" FontSize="13"
                 Background="{StaticResource BgInputBrush}"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderBrush}"
                 Padding="8,4" VerticalContentAlignment="Center"
                 Margin="0,0,0,12"/>

        <TextBlock Text="Author (optional)" FontSize="11"
                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="AuthorBox" Height="30" FontSize="12"
                 Background="{StaticResource BgInputBrush}"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderBrush}"
                 Padding="8,4" VerticalContentAlignment="Center"
                 Margin="0,0,0,12"/>

        <TextBlock Text="Description (optional)" FontSize="11"
                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="DescriptionBox" Height="60" FontSize="12"
                 Background="{StaticResource BgInputBrush}"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderBrush}"
                 Padding="8,4" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,12"/>

        <TextBlock Text="URL — Nexus / GitHub / etc. (optional)" FontSize="11"
                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="UrlBox" Height="30" FontSize="12"
                 Background="{StaticResource BgInputBrush}"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderBrush}"
                 Padding="8,4" VerticalContentAlignment="Center"
                 Margin="0,0,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource SubtleButton}"
                    Height="34" FontSize="11" Width="80"
                    Click="OnCancel" IsCancel="True"/>
            <Button Content="Import" Style="{StaticResource AccentButton}"
                    Height="34" FontSize="12" Width="100"
                    Click="OnConfirmImport" IsDefault="True" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>
