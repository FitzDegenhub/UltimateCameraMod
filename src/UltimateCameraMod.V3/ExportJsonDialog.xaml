<UserControl x:Class="UltimateCameraMod.V3.ExportJsonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:UltimateCameraMod.V3.Localization"
        Width="680" MaxHeight="750">
    <UserControl.Resources>
        <!-- TextBox style for all input fields in this dialog -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- Segmented format choice: reads like the rest of v3 (accent selection, dark inputs) -->
        <Style x:Key="ExportFormatRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Card" CornerRadius="8" Padding="14,10" SnapsToDevicePixels="True"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}"
                                Background="{StaticResource BgInputBrush}">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="18" Height="18" VerticalAlignment="Center">
                                    <Ellipse x:Name="Ring" Width="16" Height="16" StrokeThickness="2"
                                             Stroke="{StaticResource BorderBrush}" Fill="Transparent"
                                             VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <Ellipse x:Name="Inner" Width="8" Height="8" Visibility="Collapsed"
                                             Fill="{StaticResource AccentBrush}"
                                             VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                                <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Card" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource Accent}" Opacity="0.12"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Ring" Property="Stroke" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Inner" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource TextDimBrush}"/>
                                <Setter TargetName="Card" Property="Background" Value="{StaticResource BgPanelBrush}"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Card" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExportDialogLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}">
            <Setter Property="Width" Value="96"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Match MainWindow title strip -->
        <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}" Padding="22,14,22,12">
            <StackPanel>
                <TextBlock Text="{loc:Loc Title_ExportForSharing}" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Background="{StaticResource BorderBrush}"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      TextElement.Foreground="{StaticResource TextPrimaryBrush}"
                      Padding="0,4,0,0">
            <StackPanel Margin="22,18,22,22" MaxWidth="760">

                <!-- Format + help -->
                <Border Background="{StaticResource BgPanelBrush}" CornerRadius="8" Padding="18,16" Margin="0,0,0,14"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Label_Format}" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,10"/>
                        <WrapPanel Margin="0,0,0,14">
                            <RadioButton x:Name="FormatJsonRadio" GroupName="ExportFormat"
                                         Content="{loc:Loc Label_FormatJson}" Style="{StaticResource ExportFormatRadioStyle}"
                                         IsChecked="True"/>
                            <RadioButton x:Name="FormatXmlRadio" GroupName="ExportFormat"
                                         Content="{loc:Loc Label_FormatXml}" Style="{StaticResource ExportFormatRadioStyle}"/>
                            <RadioButton x:Name="FormatPazRadio" GroupName="ExportFormat"
                                         Content="{loc:Loc Label_FormatPaz}" Style="{StaticResource ExportFormatRadioStyle}"/>
                            <RadioButton x:Name="FormatPresetRadio" GroupName="ExportFormat"
                                         Content="{loc:Loc Label_FormatUcmPreset}" Style="{StaticResource ExportFormatRadioStyle}"/>
                        </WrapPanel>
                        <Border Background="{StaticResource BgInputBrush}" CornerRadius="6" Padding="12,10"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <TextBlock x:Name="HelpDetailText" TextWrapping="Wrap" FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}" LineHeight="20"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step 1 -->
                <TextBlock Text="{loc:Loc Label_ModInfoFileName}" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="2,2,0,8"/>
                <Border Background="{StaticResource BgPanelBrush}" CornerRadius="8" Padding="18,16" Margin="0,0,0,14"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,14" LineHeight="18">
                            <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">JSON</Run>
                            uses these fields in <Run FontFamily="Consolas">modinfo</Run>.
                            <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">XML</Run>
                            uses <Run FontWeight="SemiBold">Title</Run> as the default save name.
                            <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">0.paz</Run>
                            defaults to <Run FontFamily="Consolas">0.paz</Run> so you can drop it into <Run FontFamily="Consolas">0010</Run> without renaming.
                        </TextBlock>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc Label_Title}" Style="{StaticResource ExportDialogLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="JsonTitleBox" Text="UCM Camera Config"
                                     VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Loc Label_Version}" Style="{StaticResource ExportDialogLabel}"
                                       Margin="0,10,14,0"/>
                            <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="JsonVersionBox" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{loc:Loc Label_Author}" VerticalAlignment="Center"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="14,0,14,0"/>
                                <TextBox Grid.Column="2" x:Name="JsonAuthorBox" VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Loc Label_NexusUrl}" Style="{StaticResource ExportDialogLabel}"
                                       Margin="0,10,14,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="JsonNexusBox" Margin="0,10,0,0"
                                     Text="https://www.nexusmods.com/crimsondesert/mods/438" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Loc Label_Description}" Style="{StaticResource ExportDialogLabel}"
                                       VerticalAlignment="Top" Margin="0,18,14,0"/>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="JsonDescBox" Height="76" Margin="0,10,0,0"
                                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Step 2 -->
                <TextBlock x:Name="Step2Header" Text="{loc:Loc Btn_PrepareExport}" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="2,2,0,8"/>
                <Border Background="{StaticResource BgPanelBrush}" CornerRadius="8" Padding="18,16" Margin="0,0,0,14"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="Step2Body" TextWrapping="Wrap" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,14" LineHeight="18"/>
                        <Button Content="{loc:Loc Btn_PrepareExport}" Style="{StaticResource AccentButton}"
                                Click="OnPrepareFromCurrent" MinHeight="36" Padding="18,8" FontSize="12"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Step 3 -->
                <Border x:Name="ExportPreviewPanel" Visibility="Collapsed"
                        Background="{StaticResource BgPanelBrush}" CornerRadius="8" Padding="18,16" Margin="0,0,0,14"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Label_SaveExport}" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>

                        <StackPanel x:Name="JsonStatsPanel" Visibility="Collapsed" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="{StaticResource BgInputBrush}" CornerRadius="6"
                                        Margin="0,0,10,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{StaticResource AccentBrush}"
                                                CornerRadius="6,0,0,6"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,10,14,10">
                                            <TextBlock x:Name="JsonPatchCountLabel" Text="0" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                            <TextBlock Text="{loc:Loc Label_Regions}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Bottom" Margin="6,0,0,4"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Background="{StaticResource BgInputBrush}" CornerRadius="6"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{StaticResource AccentBrush}"
                                                CornerRadius="6,0,0,6"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,10,14,10">
                                            <TextBlock x:Name="JsonBytesChangedLabel" Text="0" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                            <TextBlock Text="{loc:Loc Label_BytesChanged}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Bottom" Margin="6,0,0,4"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       LineHeight="18" Margin="0,0,0,4">
                                Save the <Run FontFamily="Consolas">.json</Run>, then import it in
                                <Hyperlink NavigateUri="https://www.nexusmods.com/crimsondesert/mods/113"
                                           Foreground="{StaticResource AccentBrush}"
                                           RequestNavigate="OnExportHelpHyperlinkNavigate">JSON Mod Manager</Hyperlink>
                                or
                                <Hyperlink NavigateUri="https://www.nexusmods.com/crimsondesert/mods/207"
                                           Foreground="{StaticResource AccentBrush}"
                                           RequestNavigate="OnExportHelpHyperlinkNavigate">Crimson Desert Ultimate Mods Manager</Hyperlink>
                                (follow that tool’s import / Mods folder instructions).
                            </TextBlock>
                        </StackPanel>

                        <TextBlock x:Name="XmlSaveHint" Visibility="Collapsed" TextWrapping="Wrap" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" LineHeight="18" Margin="0,0,0,12"/>

                        <TextBlock x:Name="PazSaveHint" Visibility="Collapsed" TextWrapping="Wrap" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" LineHeight="18" Margin="0,0,0,12"/>

                        <Border Background="{StaticResource BgInputBrush}" CornerRadius="6" Padding="10,8"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,14">
                            <TextBlock x:Name="FingerprintLabel" TextWrapping="Wrap" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}" FontFamily="Consolas"
                                       LineHeight="15"/>
                        </Border>

                        <Button x:Name="SaveExportButton" Content="{loc:Loc Btn_SaveExport}" Style="{StaticResource AccentButton}"
                                Click="OnSaveExport" MinHeight="36" Padding="18,8" FontSize="12"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="StatusLabel" FontSize="11" Foreground="{StaticResource TextDimBrush}"
                           TextWrapping="Wrap" Margin="2,4,2,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
