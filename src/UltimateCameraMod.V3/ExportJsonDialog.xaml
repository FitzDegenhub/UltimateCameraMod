<Window x:Class="UltimateCameraMod.V3.ExportJsonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export JSON for Mod Manager" Width="680" Height="700"
        MinWidth="580" MinHeight="500"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource BgDarkBrush}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      TextElement.Foreground="{StaticResource TextPrimaryBrush}">
            <StackPanel Margin="28,20,28,20" MaxWidth="760">

                <!-- How it works banner -->
                <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="16,14" Margin="0,0,0,16"
                        BorderBrush="#333" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="HOW IT WORKS" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                   LineHeight="20" Margin="0,0,0,8">
                            This generates a <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">.json patch file</Run>
                            compatible with <Run FontWeight="SemiBold">Crimson Desert JSON Mod Manager v8</Run>.
                            Drop the file into the mod manager's <Run FontFamily="Consolas">Mods/</Run> folder and your camera settings
                            will appear as a toggleable mod — no UCM required.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="18">
                            The patch compares your modified camera file against vanilla byte-by-byte
                            and records only the differences. The JSON Mod Manager will only apply if those
                            <Run FontWeight="SemiBold">expected (original) bytes</Run> still match the game file.
                            After a <Run FontWeight="SemiBold">game update</Run> or if the mod manager refreshes a stale backup,
                            an old export will be skipped — point UCM at the same current install and export again.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Step 1: Mod Info -->
                <TextBlock Text="STEP 1 — NAME YOUR MOD" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="16,14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="This info appears inside the mod manager so people know what the mod is."
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Title" Width="90" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="JsonTitleBox" Text="UCM Camera Config" FontSize="12"/>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Version" Width="90" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="Author" Width="60" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       DockPanel.Dock="Right" Margin="12,0,0,0"/>
                            <TextBox x:Name="JsonAuthorBox" Width="200" DockPanel.Dock="Right" FontSize="12"/>
                            <TextBox x:Name="JsonVersionBox" FontSize="12"/>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Nexus URL" Width="90" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="JsonNexusBox"
                                     Text="https://www.nexusmods.com/crimsondesert/mods/438" FontSize="12"/>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="Description" Width="90" VerticalAlignment="Top"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0"/>
                            <TextBox x:Name="JsonDescBox" Height="70" FontSize="12"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Step 2: Generate -->
                <TextBlock Text="STEP 2 — GENERATE THE PATCH" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="16,14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,12" LineHeight="18">
                            <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Current Settings</Run>
                            uses your latest session from UCM Quick, Fine Tune, or God Mode.
                            <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">From XML File</Run>
                            lets you pick any exported <Run FontFamily="Consolas">playercamerapreset.xml</Run>.
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Generate from Current Settings" Style="{StaticResource AccentButton}"
                                    Click="OnJsonGenerate" Height="34" FontSize="12" Padding="14,0"/>
                            <Button Content="Generate from XML File..." Style="{StaticResource SubtleButton}"
                                    Click="OnJsonGenerateFromXml" Height="34" FontSize="11" Padding="12,0" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Step 3: Save (shown after generate) -->
                <Border x:Name="JsonPreviewPanel" Visibility="Collapsed"
                        Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="16,14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="STEP 3 — SAVE THE FILE" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#1a1a1a" CornerRadius="4" Padding="12,6" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="JsonPatchCountLabel" Text="0" FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text=" patch regions" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="4,0,0,5"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#1a1a1a" CornerRadius="4" Padding="12,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="JsonBytesChangedLabel" Text="0" FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text=" bytes changed" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="4,0,0,5"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,12" LineHeight="18">
                            Save the <Run FontFamily="Consolas">.json</Run> file, then drop it into
                            <Run FontFamily="Consolas">Mods/</Run> inside your Crimson Desert JSON Mod Manager installation.
                        </TextBlock>
                        <Button Content="Save .json..." Style="{StaticResource AccentButton}"
                                Click="OnJsonSave" Height="34" FontSize="12" Padding="14,0"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <TextBlock x:Name="StatusLabel" FontSize="11" Foreground="{StaticResource TextDimBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
