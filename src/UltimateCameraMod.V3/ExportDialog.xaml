<Window x:Class="UltimateCameraMod.V3.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:UltimateCameraMod.V3.Localization"
        Title="{loc:Loc Title_ExportPreset}" Width="520" Height="320" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource BgDarkBrush}">
    <StackPanel Margin="24">
        <TextBlock x:Name="TitleText" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="{loc:Loc Dlg_CopyPasteHint}" FontSize="11"
                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,10"/>
        <TextBox x:Name="CodeBox" FontFamily="Consolas" FontSize="13" Height="90"
                 Background="{StaticResource BgInputBrush}" Foreground="{StaticResource AccentBrush}"
                 BorderBrush="{StaticResource BorderBrush}" TextWrapping="Wrap"
                 IsReadOnly="True" Padding="10,8"/>
        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
            <Button x:Name="CopyBtn" Content="{loc:Loc Btn_CopyClipboard}" Style="{StaticResource AccentButton}"
                    Width="150" Height="34" Click="OnCopy"/>
            <Button Content="{loc:Loc Btn_Close}" Style="{StaticResource SubtleButton}"
                    Width="90" Height="34" Click="OnClose" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>

