<Window x:Class="UltimateCameraMod.V3.ImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:UltimateCameraMod.V3.Localization"
        Title="{loc:Loc Title_ImportPreset}" Width="520" Height="360" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource BgDarkBrush}">
    <StackPanel Margin="24">
        <TextBlock Text="{loc:Loc Dlg_PastePresetBelow}" FontSize="14"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="{loc:Loc Dlg_PasteFromHint}" FontSize="11"
                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,10"/>
        <TextBox x:Name="PasteBox" FontFamily="Consolas" FontSize="13" Height="90"
                 Background="{StaticResource BgInputBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderBrush}" TextWrapping="Wrap"
                 Padding="10,8" TextChanged="OnTextChanged"/>
        <TextBlock x:Name="PreviewText" FontSize="12" Foreground="{StaticResource TextDimBrush}"
                   Margin="0,10,0,10"/>
        <StackPanel Orientation="Horizontal">
            <Button x:Name="ImportBtn" Content="{loc:Loc Btn_ImportSave}" Style="{StaticResource AccentButton}"
                    Width="130" Height="34" Click="OnImport" IsEnabled="False"/>
            <Button Content="{loc:Loc Btn_Cancel}" Style="{StaticResource SubtleButton}"
                    Width="90" Height="34" Click="OnCancel" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>

