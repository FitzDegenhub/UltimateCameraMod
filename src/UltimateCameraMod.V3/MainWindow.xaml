<Window x:Class="UltimateCameraMod.V3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:UltimateCameraMod.V3.Controls"
        xmlns:loc="clr-namespace:UltimateCameraMod.V3.Localization"
        Title="{loc:Loc Title_MainWindow}"
        Icon="pack://application:,,,/Assets/ucm.ico"
        Width="1060" Height="1000" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="{StaticResource BgDarkBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>  <!-- Title bar -->
            <RowDefinition Height="Auto"/> <!-- Alert banner -->
            <RowDefinition Height="1"/>   <!-- Separator -->
            <RowDefinition Height="*"/>   <!-- Body -->
            <RowDefinition Height="1"/>   <!-- Separator -->
            <RowDefinition Height="56"/>  <!-- Bottom bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Title Bar ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}">
            <DockPanel Margin="20,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Loc Title_Brand}" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="  v3.1.2  |  by 0xFitz" FontSize="10"
                               Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <Ellipse x:Name="VersionDot" Width="7" Height="7" Fill="#555" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="VersionStatus" Text="{loc:Loc Status_Checking}" FontSize="9"
                               Foreground="#555" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <Button x:Name="VersionUpdateBtn" Visibility="Collapsed"
                            Style="{StaticResource SubtleButton}" FontSize="9" Padding="6,2" Height="20"
                            Foreground="#4CAF50" BorderBrush="#4CAF50" Margin="8,0,0,0"
                            Click="OnUpdateGitHubClick" Content="{loc:Loc Btn_GetUpdate}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <ComboBox x:Name="LanguageCombo" Width="110" Height="26" FontSize="11"
                              SelectionChanged="OnLanguageChanged" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="NexusMods" Style="{StaticResource SubtleButton}"
                            Foreground="#d98f40" Click="OnNexusClick" Margin="0,0,4,0"
                            BorderThickness="0" FontSize="10" Padding="8,4"/>
                    <Button Content="GitHub" Style="{StaticResource SubtleButton}"
                            Click="OnGitHubClick" BorderThickness="0" FontSize="10" Padding="8,4" Margin="0,0,4,0"/>
                    <Button x:Name="KofiBtn" Content="☕ Buy me a coffee" Style="{StaticResource SubtleButton}"
                            Click="OnKofiClick" BorderThickness="0" FontSize="10" Padding="8,4"
                            ToolTip="{loc:Loc Tip_Kofi}"
                            Foreground="#FF5E5B"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ Game Path + Alert Banner ═══ -->
        <StackPanel Grid.Row="1">
            <Border Background="{StaticResource BgPanelBrush}" Padding="20,4">
                <DockPanel>
                    <Button Content="{loc:Loc Btn_Open}" DockPanel.Dock="Right" Style="{StaticResource SubtleButton}"
                            FontSize="12" Padding="6,2" Height="22" VerticalAlignment="Center"
                            Click="OnOpenGameFolder" ToolTip="{loc:Loc Tip_OpenGameFolder}"
                            BorderThickness="0" Foreground="{StaticResource TextDimBrush}"/>
                    <TextBlock x:Name="GamePathLabel" FontFamily="Consolas" FontSize="9"
                               Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
            <Border x:Name="BannerPanel" Height="Auto" Visibility="Collapsed">
                <TextBlock x:Name="BannerText" FontSize="11" VerticalAlignment="Center" Margin="20,6"/>
            </Border>
        </StackPanel>

        <!-- ═══ Separator ═══ -->
        <Border Grid.Row="2" Background="{StaticResource BorderBrush}"/>

        <!-- Fixed body: sidebar presets + editor content -->
        <Grid x:Name="BodyChrome" Grid.Row="3" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar: Preset Manager -->
            <Border Grid.Column="0" Background="{StaticResource BgDarkBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel Margin="10,14,10,12" LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Loc Section_Presets}" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="2,0,0,8"/>

                    <!-- Bottom actions -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="{loc:Loc Btn_New}" Style="{StaticResource SubtleButton}"
                                    Click="OnPresetNew" Height="26" FontSize="10" Padding="10,0"/>
                            <Button Content="{loc:Loc Btn_Duplicate}" Style="{StaticResource SubtleButton}"
                                    Click="OnPresetManagerDuplicate" Height="26" FontSize="10" Padding="10,0" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="{loc:Loc Btn_Rename}" Style="{StaticResource SubtleButton}"
                                    Click="OnPresetManagerRename" Height="26" FontSize="10" Padding="10,0"/>
                            <Button Content="{loc:Loc Btn_Delete}" Style="{StaticResource SubtleButton}"
                                    Click="OnPresetManagerDelete" Height="26" FontSize="10" Padding="10,0" Margin="4,0,0,0"
                                    Foreground="#aa6666"/>
                        </StackPanel>
                        <StackPanel x:Name="SidebarActionButtons">
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,2,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="{loc:Loc Btn_Import}" Style="{StaticResource SubtleButton}"
                                        Click="OnImportPreset" Height="26" FontSize="10" Padding="10,0" Margin="4,0,0,0"
                                        ToolTip="{loc:Loc Tip_ImportPreset}"/>
                                <Button Content="{loc:Loc Btn_Export}" Style="{StaticResource SubtleButton}"
                                        Click="OnExportJson" Height="26" FontSize="10" Padding="10,0" Margin="4,0,0,0"
                                        ToolTip="{loc:Loc Tip_ExportPreset}"/>
                                <Button Content="{loc:Loc Btn_Restore}" Style="{StaticResource SubtleButton}"
                                        Click="OnRestore" Height="26" FontSize="10" Padding="10,0" Margin="4,0,0,0"
                                        ToolTip="{loc:Loc Tip_RestorePreset}"/>
                            </StackPanel>
                            <Button Content="{loc:Loc Btn_InstallToGame}" Style="{StaticResource AccentButton}"
                                    Click="OnInstall" Height="34" FontSize="11" Margin="0,6,0,0"
                                    ToolTip="{loc:Loc Tip_InstallToGame}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Preset list: ucm_presets, my_presets, import_presets (Imported group) -->
                    <ListBox x:Name="PresetRailList"
                             Style="{StaticResource SidebarPresetListBox}"
                             SelectionChanged="OnPresetManagerSelectionChanged"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             MinHeight="80">
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="GroupItem">
                                        <Setter Property="Margin" Value="0,0,0,2"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="GroupItem">
                                                    <Expander IsExpanded="True" Background="Transparent" BorderThickness="0"
                                                              Margin="0,6,0,0"
                                                              ExpandDirection="Down">
                                                        <Expander.Style>
                                                            <Style TargetType="Expander">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Expander">
                                                                            <StackPanel>
                                                                                <ToggleButton IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                                                              Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                                              HorizontalContentAlignment="Stretch"
                                                                                              Padding="0" Margin="0,0,0,4">
                                                                                    <ToggleButton.Template>
                                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                                            <Border Background="Transparent" Padding="0,4,0,6"
                                                                                                    BorderBrush="{StaticResource BorderBrush}"
                                                                                                    BorderThickness="0,0,0,1">
                                                                                                <ContentPresenter/>
                                                                                            </Border>
                                                                                        </ControlTemplate>
                                                                                    </ToggleButton.Template>
                                                                                    <ContentPresenter ContentSource="Header"/>
                                                                                </ToggleButton>
                                                                                <ContentPresenter x:Name="ExpanderContent" Visibility="Visible"/>
                                                                            </StackPanel>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsExpanded" Value="False">
                                                                                    <Setter TargetName="ExpanderContent" Property="Visibility" Value="Collapsed"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Expander.Style>
                                                        <Expander.Header>
                                                            <DockPanel Width="{Binding RelativeSource={RelativeSource AncestorType=Expander}, Path=ActualWidth}">
                                                                <Button DockPanel.Dock="Right" Content="&#x2B07; Browse"
                                                                        FontSize="9" Height="20" Padding="6,0"
                                                                        ToolTip="{loc:Loc Tip_BrowsePresets}"
                                                                        Click="OnBrowsePresetCatalog"
                                                                        VerticalAlignment="Center"
                                                                        Foreground="#1a1a1a" FontWeight="SemiBold"
                                                                        Margin="0,0,20,0">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Name}" Value="Community presets">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Name}" Value="UCM presets">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Border Width="3" MinHeight="13" MaxHeight="13"
                                                                            Background="{StaticResource AccentBrush}"
                                                                            CornerRadius="1" Margin="0,2,8,0"
                                                                            VerticalAlignment="Top"/>
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontSize="10" FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                                               VerticalAlignment="Center"/>
                                                                    <TextBlock FontSize="10" Margin="5,1,0,0"
                                                                               Foreground="{StaticResource TextDimBrush}"
                                                                               VerticalAlignment="Center"
                                                                               Text="&#x25BE;"/>
                                                                </StackPanel>
                                                            </DockPanel>
                                                        </Expander.Header>
                                                        <ItemsPresenter Margin="0,4,0,0"/>
                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource SidebarPresetListBoxItem}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                        <Setter Property="Height" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontSize="11"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0"/>
                                    <Button Grid.Column="1" Content="&#x27F3;" FontSize="12"
                                            Foreground="{StaticResource AccentBrush}"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="2" Margin="0,0,2,0"
                                            VerticalAlignment="Center"
                                            ToolTip="{loc:Loc Tip_UpdateAvailable}"
                                            Click="OnPresetUpdateClick"
                                            Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Triggers>
                                            <EventTrigger RoutedEvent="Button.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1.0" To="0.3" Duration="0:0:0.8"
                                                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource PresetSidebarLockButton}"
                                            Content="{Binding LockGlyph}"
                                            ToolTip="{Binding LockToolTip}"
                                            Click="OnPresetSidebarLockClick"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Editor content area -->
            <DockPanel Grid.Column="1" Margin="12,16,16,16">

                <!-- Active preset banner -->
                <Border DockPanel.Dock="Top" Background="{StaticResource BgPanelBrush}" CornerRadius="6"
                        Padding="18,14" Margin="0,0,0,10" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource AccentBrush}" CornerRadius="4"
                                Padding="10,4" VerticalAlignment="Top" Margin="0,0,14,0">
                            <TextBlock Text="{loc:Loc Label_Active}" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource BgDarkBrush}"/>
                        </Border>
                        <DockPanel Grid.Column="1">
                            <StackPanel DockPanel.Dock="Right" VerticalAlignment="Top" Margin="12,2,0,0"
                                       HorizontalAlignment="Right">
                                <TextBlock x:Name="ActivePresetAuthor" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" Text=""
                                           HorizontalAlignment="Right"/>
                                <Button x:Name="ActivePresetLinkBtn" Visibility="Collapsed"
                                        Style="{StaticResource SubtleButton}"
                                        Click="OnActivePresetLinkClick"
                                        Height="24" Padding="8,3" Margin="0,6,0,0"
                                        HorizontalAlignment="Right"
                                        FontSize="11" Foreground="{StaticResource AccentBrush}"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        Content="&#x1F517; View on Nexus" ToolTip="{loc:Loc Tip_OpenCreatorPage}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock x:Name="ActivePresetName" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="{loc:Loc Label_Draft}"/>
                                <TextBlock x:Name="ActivePresetDetail" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" Margin="0,5,0,0"
                                           Text="{loc:Loc Label_DraftDetail}"/>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>

                <!-- Editor tab bar -->
                <Border x:Name="EditorTabBar" DockPanel.Dock="Top" Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="4" Margin="0,0,0,12">
                    <DockPanel LastChildFill="False">
                        <Button x:Name="TabQuick" DockPanel.Dock="Left" Content="{loc:Loc Tab_UcmQuick}" Width="120" Height="34" FontSize="12"
                                Style="{StaticResource AccentButton}" Click="OnTabQuick" FontWeight="SemiBold"/>
                        <Button x:Name="TabFineTune" DockPanel.Dock="Left" Content="{loc:Loc Tab_FineTune}" Width="120" Height="34" FontSize="12"
                                Style="{StaticResource SubtleButton}" Click="OnTabFineTune" Margin="4,0,0,0" FontWeight="SemiBold"/>
                        <Button x:Name="TabGodMode" DockPanel.Dock="Right" Content="{loc:Loc Tab_GodMode}" Width="120" Height="34" FontSize="12"
                                Style="{StaticResource SubtleButton}" Click="OnTabGodMode" FontWeight="SemiBold"/>
                    </DockPanel>
                </Border>

                <!-- Editor views (only one visible at a time) -->
                <Grid x:Name="EditorHost">

        <!-- ═══ SimpleView (visible by default) ═══ -->
        <Grid x:Name="SimpleView" PreviewMouseDown="OnEditorPreviewMouseDown">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="16,14" Margin="0,0,0,14">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="{loc:Loc Btn_Undo}" Style="{StaticResource SubtleButton}"
                                    Click="OnUndo" Height="24" FontSize="10" Padding="10,0"
                                    VerticalAlignment="Top" ToolTip="{loc:Loc Tip_UndoSlider}"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Section_UcmQuick}" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                                <TextBlock Text="{loc:Loc Help_UcmQuickIntro}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="18"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Top row: Custom Offsets + Global Settings side by side -->
                    <Grid x:Name="SettingsPanel" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN: Custom Offsets + Center HUD stacked -->
                        <StackPanel Grid.Column="0">

                        <!-- CUSTOM OFFSETS -->
                        <DockPanel x:Name="QuickOffsetsPanel">
                        <TextBlock DockPanel.Dock="Top" Text="{loc:Loc Section_CustomOffsets}" Style="{StaticResource SectionHeader}"/>
                    <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Margin="0,6,0,0" Padding="16,14">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="{loc:Loc Label_Distance}" Style="{StaticResource FieldLabel}" Grid.Row="0"/>
                                <Slider x:Name="DistSlider" Grid.Row="0" Grid.Column="1"
                                        Minimum="1.5" Maximum="12" Value="5" TickFrequency="0.1"
                                        IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                                <TextBlock x:Name="DistLabel" Grid.Row="0" Grid.Column="2"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Text="5.0"/>

                                <TextBlock Text="{loc:Loc Label_Height}" Style="{StaticResource FieldLabel}" Grid.Row="1"/>
                                <Slider x:Name="HeightSlider" Grid.Row="1" Grid.Column="1"
                                        Minimum="-1.6" Maximum="1.5" Value="0" TickFrequency="0.1"
                                        IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                                <TextBlock x:Name="HeightLabel" Grid.Row="1" Grid.Column="2"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Text="0.0"/>

                                <TextBlock Text="{loc:Loc Label_HShift}" Style="{StaticResource FieldLabel}" Grid.Row="2"/>
                                <Slider x:Name="HShiftSlider" Grid.Row="2" Grid.Column="1"
                                        Minimum="-3" Maximum="3" Value="0" TickFrequency="0.1"
                                        IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                                <TextBlock x:Name="HShiftLabel" Grid.Row="2" Grid.Column="2"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Text="0.0"/>

                                <TextBlock x:Name="HShiftTip" Grid.Row="3" Grid.ColumnSpan="3"
                                           FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                           TextWrapping="Wrap" LineHeight="14"
                                           Text="{loc:Loc Help_HShiftTipUnlocked}"
                                           Margin="0,4,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                        </DockPanel>

                        <!-- CENTER HUD -->
                        <DockPanel x:Name="QuickHudPanel" Margin="0,6,0,0">
                            <TextBlock DockPanel.Dock="Top" Text="{loc:Loc Section_CenterHud}" Style="{StaticResource SectionHeader}"/>
                            <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Margin="0,6,0,0" Padding="16,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{loc:Loc Label_CenterHud}" Style="{StaticResource FieldLabel}" Grid.Row="0"/>
                                    <CheckBox x:Name="CenterHudCheck" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                              Content="{loc:Loc Check_CenterHud}"
                                              Checked="OnCenterHudChanged" Unchecked="OnCenterHudChanged" Margin="0,0,0,8"/>

                                    <TextBlock Text="{loc:Loc Label_SafeArea}" Style="{StaticResource FieldLabel}" Grid.Row="1"/>
                                    <ComboBox x:Name="HudModeCombo" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                              Height="32" IsEnabled="False"
                                              SelectionChanged="OnHudModeChanged" Margin="0,0,0,8">
                                        <ComboBoxItem Content="{loc:Loc Combo_Hud16x9}" Tag="1920" IsSelected="True"/>
                                        <ComboBoxItem Content="{loc:Loc Combo_Hud21x9}" Tag="2520"/>
                                    </ComboBox>

                                    <TextBlock Grid.Row="2" Grid.ColumnSpan="3"
                                               FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                               TextWrapping="Wrap" LineHeight="14" Margin="0,4,0,0"
                                               Text="{loc:Loc Help_CenterHudDesc}"/>
                                </Grid>
                            </Border>
                        </DockPanel>

                        </StackPanel>

                        <!-- GLOBAL SETTINGS (right) -->
                        <DockPanel Grid.Column="2" x:Name="QuickGlobalPanel">
                        <TextBlock DockPanel.Dock="Top" Text="{loc:Loc Section_GlobalSettings}" Style="{StaticResource SectionHeader}"/>
                    <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Margin="0,6,0,0" Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{loc:Loc Label_Fov}" Style="{StaticResource FieldLabel}" Grid.Row="0"/>
                            <ComboBox x:Name="FovCombo" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                      Height="32" SelectionChanged="OnSettingChanged" Margin="0,0,0,8"
                                      ToolTip="{loc:Loc Tip_FovCombo}"/>

                            <TextBlock Text="{loc:Loc Label_LockOnZoom}" Style="{StaticResource FieldLabel}" Grid.Row="1"/>
                            <Slider x:Name="CombatPullbackSlider" Grid.Row="1" Grid.Column="1"
                                    Minimum="-0.6" Maximum="0.6" SmallChange="0.05" LargeChange="0.1"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    ValueChanged="OnCombatPullbackChanged"
                                    VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="CombatPullbackLabel" Grid.Row="1" Grid.Column="2"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,0,8"
                                       Text=" 0%"/>

                            <TextBlock Grid.Row="2" Grid.ColumnSpan="3"
                                       FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                       TextWrapping="Wrap" LineHeight="14" Margin="0,0,0,8"
                                       Text="{loc:Loc Help_LockOnZoomDesc}"/>

                            <TextBlock Text="{loc:Loc Label_LockOnAutoRotate}" Style="{StaticResource FieldLabel}" Grid.Row="3"/>
                            <CheckBox x:Name="LockOnAutoRotateCheck" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                      Content="{loc:Loc Check_LockOnAutoRotate}"
                                      Checked="OnSettingChanged" Unchecked="OnSettingChanged" Margin="0,0,0,8"
                                      ToolTip="{loc:Loc Tip_LockOnAutoRotate}"/>

                            <TextBlock Text="{loc:Loc Label_CenteredCamera}" Style="{StaticResource FieldLabel}" Grid.Row="4"/>
                            <CheckBox x:Name="BaneCheck" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                                      Content="{loc:Loc Check_CenterCharacterShort}"
                                      Checked="OnBaneChanged" Unchecked="OnBaneChanged" Margin="0,0,0,8"
                                      ToolTip="{loc:Loc Tip_CenteredCamera}"/>

                            <TextBlock Text="{loc:Loc Label_MountCamera}" Style="{StaticResource FieldLabel}" Grid.Row="5"/>
                            <CheckBox x:Name="MountHeightCheck" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                                      Content="{loc:Loc Check_MountHeight}"
                                      Checked="OnSettingChanged" Unchecked="OnSettingChanged" Margin="0,0,0,8"/>

                            <TextBlock Text="{loc:Loc Label_Steadycam}" Style="{StaticResource FieldLabel}" Grid.Row="6"/>
                            <CheckBox x:Name="SteadycamCheck" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2"
                                      Content="{loc:Loc Check_Steadycam}"
                                      IsChecked="True" Margin="0,0,0,8"
                                      ToolTip="{loc:Loc Tip_Steadycam}"/>

                        </Grid>
                    </Border>
                        </DockPanel>
                    </Grid>

                    <!-- Bottom row: Camera Preview + FoV Preview side by side -->
                    <Grid x:Name="PreviewsPanel" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Column="0">
                            <TextBlock DockPanel.Dock="Top" Text="{loc:Loc Section_CameraPreview}" Style="{StaticResource SectionHeader}"/>
                            <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Margin="0,6,0,0" Padding="6">
                                <controls:CameraPreview x:Name="Preview"/>
                            </Border>
                        </DockPanel>

                        <DockPanel Grid.Column="2">
                            <TextBlock DockPanel.Dock="Top" Text="{loc:Loc Section_FieldOfView}" Style="{StaticResource SectionHeader}"/>
                            <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Margin="0,6,0,0" Padding="6">
                                <StackPanel VerticalAlignment="Center">
                                    <controls:FovPreview x:Name="FovPreviewCtrl"/>
                                    <TextBlock FontSize="9" Foreground="{StaticResource TextDimBrush}" Margin="0,4,0,0"
                                               HorizontalAlignment="Center" TextWrapping="Wrap"
                                               Text="{loc:Loc Help_PreviewShiftExplain}"/>
                                </StackPanel>
                            </Border>
                        </DockPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══ AdvancedControlsView (hidden) ═══ -->
        <Grid x:Name="AdvancedControlsView" Visibility="Collapsed" PreviewMouseDown="OnEditorPreviewMouseDown">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Margin="16,12,20,12">
                <StackPanel x:Name="AdvCtrlPanel" HorizontalAlignment="Stretch">

                    <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="12,10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Help_FineTuneIntro}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="18"/>
                            <TextBlock Text="{loc:Loc Help_FineTuneGodModeNote}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="18" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                        <DockPanel>
                            <Button Content="{loc:Loc Btn_Clear}" DockPanel.Dock="Right" Style="{StaticResource SubtleButton}"
                                    Click="OnAdvCtrlClearSearch" Height="26" FontSize="11" Padding="10,2"/>
                            <TextBlock Text="{loc:Loc Label_Search}" DockPanel.Dock="Left" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="AdvCtrlSearchBox" Height="26"
                                     VerticalContentAlignment="Center"
                                     Padding="8,3"
                                     TextChanged="OnAdvCtrlSearchChanged"/>
                        </DockPanel>
                    </Border>

                    <!-- Section A: On-Foot Zoom Levels -->
                    <Expander x:Name="AdvSectionA" IsExpanded="True" Margin="0,0,0,8">
                        <Expander.Header>
                            <TextBlock Text="{loc:Loc Section_FineTuneOnFoot}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <Border Background="{StaticResource BgPanelBrush}" CornerRadius="0,0,6,6" Padding="12,12,8,12">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Help_OnFootZoomDesc}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,12" LineHeight="18"/>
                                <Grid x:Name="AdvCtrlOnFootGrid"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- Section B: Horse / Mount Zoom Levels -->
                    <Expander x:Name="AdvSectionB" IsExpanded="True" Margin="0,0,0,8">
                        <Expander.Header>
                            <TextBlock Text="{loc:Loc Section_FineTuneMount}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <Border Background="{StaticResource BgPanelBrush}" CornerRadius="0,0,6,6" Padding="12,12,8,12">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Help_HorseZoomDesc}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,12" LineHeight="18"/>
                                <Grid x:Name="AdvCtrlMountGrid"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- Section C: Global / FoV -->
                    <Expander x:Name="AdvSectionC" IsExpanded="True" Margin="0,0,0,8">
                        <Expander.Header>
                            <TextBlock Text="{loc:Loc Section_FineTuneGlobalFov}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <Border Background="{StaticResource BgPanelBrush}" CornerRadius="0,0,6,6" Padding="12,12,8,12">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Help_GlobalFovDesc}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,12" LineHeight="18"/>
                                <Grid x:Name="AdvCtrlGlobalGrid"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- Section D: Special Mounts / Traversal -->
                    <Expander x:Name="AdvSectionD" IsExpanded="True" Margin="0,0,0,8">
                        <Expander.Header>
                            <TextBlock Text="{loc:Loc Section_FineTuneSpecialMounts}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <Border Background="{StaticResource BgPanelBrush}" CornerRadius="0,0,6,6" Padding="12,12,8,12">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Help_SpecialMountsDesc}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,12" LineHeight="18"/>
                                <Grid x:Name="AdvCtrlSpecialMountGrid"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- Section E: Combat / Lock-On -->
                    <Expander x:Name="AdvSectionE" IsExpanded="True" Margin="0,0,0,8">
                        <Expander.Header>
                            <TextBlock Text="{loc:Loc Section_FineTuneCombat}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <Border Background="{StaticResource BgPanelBrush}" CornerRadius="0,0,6,6" Padding="12,12,8,12">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Help_CombatDesc}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,12" LineHeight="18"/>
                                <Grid x:Name="AdvCtrlCombatGrid"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- Section F: Camera Smoothing / Steadycam -->
                    <Expander x:Name="AdvSectionF" IsExpanded="True" Margin="0,0,0,8">
                        <Expander.Header>
                            <TextBlock Text="{loc:Loc Section_FineTuneSmoothing}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <Border Background="{StaticResource BgPanelBrush}" CornerRadius="0,0,6,6" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Help_SmoothingDesc}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,12" LineHeight="18"/>
                                <Grid x:Name="AdvCtrlSmoothGrid"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- Section G: Aiming / Crosshair Position -->
                    <Expander x:Name="AdvSectionG" IsExpanded="True" Margin="0,0,0,8">
                        <Expander.Header>
                            <TextBlock Text="{loc:Loc Section_FineTuneAiming}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <Border Background="{StaticResource BgPanelBrush}" CornerRadius="0,0,6,6" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Help_AimingDesc}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,12" LineHeight="18"/>
                                <Grid x:Name="AdvCtrlAimGrid"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══ ExpertView (hidden) ═══ -->
        <Grid x:Name="ExpertView" Visibility="Collapsed" PreviewMouseDown="OnEditorPreviewMouseDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}" Padding="16,10">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Help_GodModeIntro}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="18"/>
                    <TextBlock Text="{loc:Loc Help_GodModeSessionNote}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="18" Margin="0,8,0,0"/>
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="18" Margin="0,8,0,0">
                        <Run Foreground="{StaticResource TextPrimaryBrush}" Text="{loc:Loc Label_GodModeWhiteVanilla}"/>
                        <Run>  |  </Run>
                        <Run Foreground="{StaticResource AccentBrush}" Text="{loc:Loc Label_GodModeGoldModified}"/>
                        <Run>  |  </Run>
                        <Run Foreground="{StaticResource SuccessBrush}" Text="{loc:Loc Label_GodModeGreenSacred}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Search & filter -->
            <Border x:Name="ExpertToolbarBorder" Grid.Row="1" Background="#1e1e1e">
                <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                    <Button Content="{loc:Loc Btn_ExpandAll}" Style="{StaticResource SubtleButton}"
                            Click="OnAdvExpandAll" Height="26" FontSize="11" Padding="10,2" Margin="0,0,8,0"/>
                    <TextBox x:Name="AdvSearchBox" Width="200" Height="26" FontSize="11"
                             Foreground="#e0e0e0" CaretBrush="#e0e0e0"
                             Background="#2e2e2e" BorderBrush="#333333" BorderThickness="1"
                             Padding="6,4" VerticalContentAlignment="Center"
                             Style="{x:Null}"
                             KeyUp="OnAdvSearchChanged"/>
                    <ComboBox x:Name="AdvFilterCombo" Width="160" Height="26" Margin="8,0,0,0"
                              SelectionChanged="OnAdvFilterChanged"/>
                    <TextBlock x:Name="AdvRowCountLabel" FontSize="10"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- DataGrid -->
            <DataGrid x:Name="ExpertDataGrid" Grid.Row="2"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      CanUserReorderColumns="False" SelectionMode="Single" SelectionUnit="Cell"
                      CellEditEnding="OnExpertCellEditEnding"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#2a2a2a"
                      Background="{StaticResource BgDarkBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      RowBackground="{StaticResource BgDarkBrush}"
                      AlternatingRowBackground="#1e1e1e"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="0"
                      FontSize="11" RowHeight="26"
                      ColumnHeaderHeight="30"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.IsDeferredScrollingEnabled="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource BgPanelBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="BorderBrush" Value="#2a2a2a"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="6,2"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#30c8a24e"/>
                            </Trigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsModified}" Value="True"/>
                                    <Condition Binding="{Binding IsUserEdited}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </MultiDataTrigger>
                            <DataTrigger Binding="{Binding IsUserEdited}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <Expander IsExpanded="False" Background="Transparent" BorderThickness="0">
                                                <Expander.Header>
                                                    <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}" Margin="4,2"/>
                                                </Expander.Header>
                                                <ItemsPresenter/>
                                            </Expander>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </DataGrid.GroupStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:Loc Header_Section}" Binding="{Binding Section, Mode=OneWay}" Width="200" IsReadOnly="True"/>
                    <DataGridTextColumn Header="{loc:Loc Header_SubElement}" Binding="{Binding SubElement, Mode=OneWay}" Width="140" IsReadOnly="True"/>
                    <DataGridTextColumn Header="{loc:Loc Header_Attribute}" Binding="{Binding Attribute, Mode=OneWay}" Width="250" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="ToolTip" Value="{Binding AttributeDoc}"/>
                                <Setter Property="ToolTipService.ShowDuration" Value="12000"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{loc:Loc Header_Value}" Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120">
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{loc:Loc Header_Vanilla}" Binding="{Binding VanillaValue, Mode=OneWay}" Width="120" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>


                </Grid>
            </DockPanel>
        </Grid>

        <!-- ═══ Separator ═══ -->
        <Border Grid.Row="4" Background="{StaticResource BorderBrush}"/>

        <!-- ═══ Bottom Bar ═══ -->
        <Border Grid.Row="5" Background="{StaticResource BgPanelBrush}">
            <DockPanel Margin="20,0" LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                            x:Name="GameUpdateStrip" Visibility="Collapsed">
                    <Ellipse x:Name="GameUpdateDot" Width="7" Height="7" Fill="#E6A23C" VerticalAlignment="Center"
                             Margin="0,0,6,0"/>
                    <TextBlock x:Name="GameUpdateText" FontSize="10" MaxWidth="420" TextWrapping="Wrap"
                               Foreground="{StaticResource WarnBrush}" VerticalAlignment="Center"/>
                    <Button x:Name="GameUpdateSnoozeBtn" Content="{loc:Loc Btn_Snooze7d}" Margin="10,0,0,0"
                            Style="{StaticResource SubtleButton}" FontSize="9" Padding="8,2" Height="22"
                            Click="OnGameUpdateSnoozeClick" ToolTip="{loc:Loc Tip_Snooze7d}"/>
                    <Button x:Name="GameUpdateDismissBtn" Content="{loc:Loc Btn_Dismiss}" Margin="6,0,0,0"
                            Style="{StaticResource SubtleButton}" FontSize="9" Padding="8,2" Height="22"
                            Click="OnGameUpdateDismissClick" ToolTip="{loc:Loc Tip_DismissUntilRelaunch}"/>
                </StackPanel>
                <TextBlock x:Name="StatusLabel" Text="{loc:Loc Status_Ready}" FontSize="11"
                           Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <Border x:Name="SaveToast"
                Grid.RowSpan="6"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,72"
                Background="#EE111111"
                BorderBrush="#3A4CAF50"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,8"
                Panel.ZIndex="20">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="SaveToastDot" Width="8" Height="8" Fill="#4CAF50" VerticalAlignment="Center"/>
                <TextBlock x:Name="SaveToastText"
                           Margin="8,0,0,0"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           Text="{loc:Loc Label_Saved}"/>
            </StackPanel>
        </Border>

        <Border x:Name="GlobalBusyOverlay"
                Grid.RowSpan="6"
                Visibility="Collapsed"
                Background="#CC0a0a0a"
                Panel.ZIndex="40"
                IsHitTestVisible="True">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="360">
                <ProgressBar IsIndeterminate="True" Height="6" Width="280"
                             Foreground="{StaticResource AccentBrush}"/>
                <TextBlock x:Name="GlobalBusyText"
                           Margin="0,14,0,0"
                           Text="{loc:Loc Label_Working}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- In-app overlay dialog host (replaces separate Window dialogs) -->
        <Border x:Name="OverlayHost" Grid.RowSpan="6" Panel.ZIndex="90"
                Visibility="Collapsed" Background="#CC000000" IsHitTestVisible="True"
                MouseDown="OnOverlayBackdropClick">
            <Border x:Name="OverlayCard" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#242424" BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2" CornerRadius="10" Padding="24,20"
                    MaxWidth="800" MaxHeight="850">
                <ContentPresenter x:Name="OverlayContent"/>
            </Border>
        </Border>

        <!-- First-launch tutorial overlay -->
        <Canvas x:Name="TutorialCanvas" Grid.RowSpan="6" Panel.ZIndex="100" Visibility="Collapsed"/>
    </Grid>
</Window>
