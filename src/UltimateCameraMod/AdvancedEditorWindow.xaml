<Window x:Class="UltimateCameraMod.AdvancedEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Advanced Camera Settings" Width="1100" Height="750"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource BgDarkBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}">
            <DockPanel Margin="16,0">
                <TextBlock Text="ADVANCED CAMERA SETTINGS" FontSize="13" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBox x:Name="SearchBox" Width="200" Height="26" FontSize="11"
                             Tag="Search attributes..." KeyUp="OnSearchChanged"/>
                    <ComboBox x:Name="FilterCombo" Width="160" Height="26" Margin="8,0,0,0"
                              SelectionChanged="OnFilterChanged"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource BorderBrush}"/>

        <!-- Toolbar -->
        <Border Grid.Row="2" Background="{StaticResource BgPanelBrush}">
            <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <Button Content="Reset to Defaults" Style="{StaticResource SubtleButton}"
                        Click="OnResetDefaults" Height="28" FontSize="11" Padding="12,4"/>
                <Button Content="Export String" Style="{StaticResource SubtleButton}"
                        Click="OnExportString" Height="28" FontSize="11" Padding="12,4" Margin="6,0,0,0"
                        Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"/>
                <Button Content="Import String" Style="{StaticResource SubtleButton}"
                        Click="OnImportString" Height="28" FontSize="11" Padding="12,4" Margin="6,0,0,0"
                        Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"/>
                <TextBlock x:Name="RowCountLabel" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="DataGridView" Grid.Row="3"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  CanUserReorderColumns="False" SelectionMode="Single" SelectionUnit="Cell"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#2a2a2a"
                  Background="{StaticResource BgDarkBrush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  RowBackground="{StaticResource BgDarkBrush}"
                  AlternatingRowBackground="#1e1e1e"
                  BorderBrush="{StaticResource BorderBrush}" BorderThickness="0"
                  FontSize="11" RowHeight="26"
                  ColumnHeaderHeight="30">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource BgPanelBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                    <Setter Property="FontSize" Value="10"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="BorderBrush" Value="#2a2a2a"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="6,2"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#30c8a24e"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding IsModified}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="GroupItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GroupItem">
                                        <Expander IsExpanded="False" Background="Transparent" BorderThickness="0">
                                            <Expander.Header>
                                                <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentBrush}" Margin="4,2"/>
                                            </Expander.Header>
                                            <ItemsPresenter/>
                                        </Expander>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </DataGrid.GroupStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="SECTION" Binding="{Binding Section}" Width="220" IsReadOnly="True"/>
                <DataGridTextColumn Header="SUB-ELEMENT" Binding="{Binding SubElement}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="ATTRIBUTE" Binding="{Binding Attribute}" Width="170" IsReadOnly="True"/>
                <DataGridTextColumn Header="VALUE" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="120">
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="4,2"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="VANILLA" Binding="{Binding VanillaValue}" Width="120" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4" Background="{StaticResource BorderBrush}"/>

        <!-- Bottom bar -->
        <Border Grid.Row="5" Background="{StaticResource BgPanelBrush}">
            <DockPanel Margin="16,0">
                <TextBlock x:Name="StatusLabel" Text="Ready" FontSize="11"
                           Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="ApplyBtn" Content="Apply to Game" Style="{StaticResource AccentButton}"
                            Click="OnApplyToGame" Width="130" Height="30" FontSize="12"/>
                    <Button Content="Close" Style="{StaticResource SubtleButton}"
                            Click="OnCloseClick" Width="80" Height="30" Margin="6,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
