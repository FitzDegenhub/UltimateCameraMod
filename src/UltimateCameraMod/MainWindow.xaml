<Window x:Class="UltimateCameraMod.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:UltimateCameraMod.Controls"
        Title="Ultimate Camera Mod v2.2"
        Icon="icon.ico"
        Width="1060" Height="960" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>  <!-- Title bar -->
            <RowDefinition Height="Auto"/> <!-- Alert banner -->
            <RowDefinition Height="1"/>   <!-- Separator -->
            <RowDefinition Height="*"/>   <!-- Body -->
            <RowDefinition Height="1"/>   <!-- Separator -->
            <RowDefinition Height="56"/>  <!-- Bottom bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Title Bar ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}">
            <DockPanel Margin="20,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="ULTIMATE CAMERA MOD" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="  v2.3  |  by 0xFitz" FontSize="10"
                               Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <Ellipse x:Name="VersionDot" Width="7" Height="7" Fill="#555" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="VersionStatus" Text="checking..." FontSize="9"
                               Foreground="#555" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <Button x:Name="VersionUpdateBtn" Visibility="Collapsed"
                            Style="{StaticResource SubtleButton}" FontSize="9" Padding="6,2" Height="20"
                            Foreground="#4CAF50" BorderBrush="#4CAF50" Margin="8,0,0,0"
                            Click="OnUpdateNexusClick" Content="Get update"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Button Content="⬡  NexusMods" Style="{StaticResource SubtleButton}"
                            Foreground="#d98f40" Click="OnNexusClick" Margin="0,0,4,0"
                            BorderThickness="0" FontSize="10" Padding="8,4"/>
                    <Button Content="⚑  GitHub" Style="{StaticResource SubtleButton}"
                            Click="OnGitHubClick" BorderThickness="0" FontSize="10" Padding="8,4"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ Alert Banner ═══ -->
        <Border x:Name="BannerPanel" Grid.Row="1" Height="Auto" Visibility="Collapsed">
            <TextBlock x:Name="BannerText" FontSize="11" VerticalAlignment="Center" Margin="20,6"/>
        </Border>

        <!-- ═══ Separator ═══ -->
        <Border Grid.Row="2" Background="{StaticResource BorderBrush}"/>

        <!-- ═══ Body: Simple Mode ═══ -->
        <Grid x:Name="SimpleView" Grid.Row="3" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520"/>
                <ColumnDefinition Width="440"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left Column: Controls ── -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,20,0">
                <StackPanel>
                    <!-- Game path -->
                    <TextBlock x:Name="GamePathLabel" FontFamily="Consolas" FontSize="9"
                               Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,12"/>

                    <!-- CAMERA STYLE section -->
                    <TextBlock Text="CAMERA STYLE" Style="{StaticResource SectionHeader}"/>

                    <!-- Tab bar -->
                    <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Margin="0,6,0,0" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="TabPresets" Content="Presets" Width="140" Height="32"
                                    Style="{StaticResource AccentButton}" Click="OnTabPresets" FontSize="12"/>
                            <Button x:Name="TabCustom" Content="Custom" Width="140" Height="32"
                                    Style="{StaticResource SubtleButton}" Click="OnTabCustom" FontSize="12"
                                    BorderThickness="0" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Tab content -->
                    <Border x:Name="PresetsBorder" Background="{StaticResource BgPanelBrush}" CornerRadius="6" Margin="0,4,0,0" Padding="16,14">
                        <!-- Presets tab -->
                        <StackPanel x:Name="PresetsPanel">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Camera style" Style="{StaticResource FieldLabel}" Grid.Column="0"/>
                                <ComboBox x:Name="StyleCombo" Grid.Column="1" Height="32"
                                          SelectionChanged="OnSettingChanged"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Custom tab (hidden by default) -->
                    <Border x:Name="CustomPanel" Background="{StaticResource BgPanelBrush}"
                            CornerRadius="6" Margin="0,4,0,0" Padding="16,14" Visibility="Collapsed">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Saved preset" Style="{StaticResource FieldLabel}" Grid.Row="0"/>
                                <ComboBox x:Name="PresetCombo" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                          Height="32" SelectionChanged="OnPresetSelected" Margin="0,0,0,8"/>

                                <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1"
                                        Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>

                                <TextBlock Text="Distance" Style="{StaticResource FieldLabel}" Grid.Row="2"/>
                                <Slider x:Name="DistSlider" Grid.Row="2" Grid.Column="1"
                                        Minimum="1.5" Maximum="12" Value="5" TickFrequency="0.1"
                                        IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                                <TextBlock x:Name="DistLabel" Grid.Row="2" Grid.Column="2"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Text="5.0"/>

                                <TextBlock Text="Height" Style="{StaticResource FieldLabel}" Grid.Row="3"/>
                                <Slider x:Name="HeightSlider" Grid.Row="3" Grid.Column="1"
                                        Minimum="-1.6" Maximum="0.5" Value="0" TickFrequency="0.1"
                                        IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                                <TextBlock x:Name="HeightLabel" Grid.Row="3" Grid.Column="2"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Text="0.0"/>

                                <TextBlock Text="Horizontal shift" Style="{StaticResource FieldLabel}" Grid.Row="4"/>
                                <Slider x:Name="HShiftSlider" Grid.Row="4" Grid.Column="1"
                                        Minimum="-3" Maximum="3" Value="0" TickFrequency="0.1"
                                        IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                                <TextBlock x:Name="HShiftLabel" Grid.Row="4" Grid.Column="2"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Text="0.0"/>

                                <TextBlock x:Name="HShiftTip" Grid.Row="5" Grid.ColumnSpan="3"
                                           FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                           Text="How far left/right the camera sits from the character. Centered camera locks this to 0."
                                           Margin="0,0,0,4"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Save preset" Style="{StaticResource SubtleButton}"
                                        Click="OnSavePreset" Width="100" Height="28" FontSize="11"/>
                                <Button Content="Delete preset" Style="{StaticResource SubtleButton}"
                                        Click="OnDeletePreset" Width="100" Height="28" FontSize="11"
                                        Foreground="#aa6666" Margin="4,0,0,0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="SHARE" FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <Button Content="Export string" Style="{StaticResource SubtleButton}"
                                        Click="OnExportString" Width="100" Height="28" FontSize="11"
                                        Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"/>
                                <Button Content="Import string" Style="{StaticResource SubtleButton}"
                                        Click="OnImportString" Width="100" Height="28" FontSize="11"
                                        Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"
                                        Margin="4,0,0,0"/>
                            </StackPanel>

                            <TextBlock FontSize="9" Foreground="{StaticResource TextDimBrush}" Margin="0,6,0,0"
                                       Text="Limits: Dist 1.5-12.0  |  Height -1.6 to 0.5  |  Shift -3.0 to 3.0"/>
                        </StackPanel>
                    </Border>

                    <!-- GLOBAL SETTINGS section -->
                    <TextBlock Text="GLOBAL SETTINGS" Style="{StaticResource SectionHeader}"/>
                    <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Margin="0,6,0,0" Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Field of view" Style="{StaticResource FieldLabel}" Grid.Row="0"/>
                            <ComboBox x:Name="FovCombo" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                      Height="32" SelectionChanged="OnSettingChanged" Margin="0,0,0,8"/>

                            <TextBlock Text="Combat camera" Style="{StaticResource FieldLabel}" Grid.Row="1"/>
                            <ComboBox x:Name="CombatCombo" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                      Height="32" SelectionChanged="OnSettingChanged" Margin="0,0,0,8"/>

                            <TextBlock Text="Centered camera" Style="{StaticResource FieldLabel}" Grid.Row="2"/>
                            <CheckBox x:Name="BaneCheck" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                      Content="Center character on screen (locks Horizontal Shift to 0)"
                                      Checked="OnBaneChanged" Unchecked="OnBaneChanged" Margin="0,0,0,8"/>

                            <TextBlock Text="Mount camera" Style="{StaticResource FieldLabel}" Grid.Row="3"/>
                            <CheckBox x:Name="MountHeightCheck" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                      Content="Match mount/horse height to player camera height"
                                      Checked="OnSettingChanged" Unchecked="OnSettingChanged" Margin="0,0,0,8"/>

                            <TextBlock Text="Steadycam" Style="{StaticResource FieldLabel}" Grid.Row="4"/>
                            <CheckBox x:Name="SteadycamCheck" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                                      Content="Smooth camera transitions (eliminates zoom jitter between states)"
                                      IsChecked="True" Margin="0,0,0,8"
                                      ToolTip="Smooths blending, damping and velocity offsets between movement states. Disable to restore vanilla camera transitions."/>

                            <TextBlock Text="Extra zoom" Style="{StaticResource FieldLabel}" Grid.Row="5"/>
                            <CheckBox x:Name="ExtraZoomCheck" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                                      Content="Add two extra zoom-out levels (scroll further out on foot and mounted)"
                                      Margin="0,0,0,8"
                                      ToolTip="Injects ZoomLevel 5 and 6 into gameplay camera states, letting you scroll much further out."/>

                            <TextBlock Text="Horse first person" Style="{StaticResource FieldLabel}" Grid.Row="6"/>
                            <CheckBox x:Name="HorseFirstPersonCheck" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2"
                                      Content="Enable first-person view while mounted (scroll all the way in)"
                                      Margin="0,0,0,8"
                                      ToolTip="Adds a first-person zoom level to horse and mount states using the character eye bone as pivot."/>

                            <TextBlock Text="HUD X-axis" Style="{StaticResource FieldLabel}" Grid.Row="7" Opacity="0.4"/>
                            <CheckBox x:Name="HudCheck" Grid.Row="7" Grid.Column="1"
                                      Content="Disabled — recent game update causes publisher watermark"
                                      IsEnabled="False" Margin="0,0,0,4" Opacity="0.5"/>

                            <Slider x:Name="HudWidthSlider" Grid.Row="8" Grid.Column="1"
                                    Minimum="1200" Maximum="3840" Value="2520" TickFrequency="20"
                                    IsSnapToTickEnabled="True" ValueChanged="OnHudSliderChanged"
                                    IsEnabled="False" Margin="0,0,0,8" Opacity="0.3"/>
                            <TextBlock x:Name="HudWidthLabel" Grid.Row="8" Grid.Column="2"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource TextDimBrush}"
                                       VerticalAlignment="Center" Text="Off"/>

                            <TextBlock Text="HUD Y-axis" Style="{StaticResource FieldLabel}" Grid.Row="9" Opacity="0.4"/>
                            <CheckBox x:Name="HudHeightCheck" Grid.Row="9" Grid.Column="1"
                                      Content="Disabled — recent game update causes publisher watermark"
                                      IsEnabled="False" Margin="0,0,0,4" Opacity="0.5"/>

                            <Slider x:Name="HudHeightSlider" Grid.Row="10" Grid.Column="1"
                                    Minimum="500" Maximum="2160" Value="1080" TickFrequency="10"
                                    IsSnapToTickEnabled="True" ValueChanged="OnHudSliderChanged"
                                    IsEnabled="False" Margin="0,0,0,8" Opacity="0.3"/>
                            <TextBlock x:Name="HudHeightLabel" Grid.Row="10" Grid.Column="2"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource TextDimBrush}"
                                       VerticalAlignment="Center" Text="Off"/>
                        </Grid>
                    </Border>
                    <!-- Update notice -->
                    <Border Background="#1affc107" CornerRadius="4" Margin="0,14,0,0" Padding="10,8">
                        <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#b0b0b0">
                            <Run FontWeight="SemiBold" Foreground="#d98f40">Note:</Run>
                            <Run> Game updates will overwrite modded files. After each Crimson Desert update, re-run UCM Install to restore your camera settings.</Run>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ── Right Column: Previews ── -->
            <StackPanel Grid.Column="1">
                <TextBlock Text="CAMERA PREVIEW" Style="{StaticResource SectionHeader}"/>
                <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Margin="0,6,0,8" Padding="6">
                    <controls:CameraPreview x:Name="Preview"/>
                </Border>
                <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="6">
                    <controls:FovPreview x:Name="FovPreviewCtrl"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ═══ Body: Advanced Mode ═══ -->
        <Grid x:Name="AdvancedView" Grid.Row="3" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Row 1: Preset management -->
            <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}">
                <DockPanel Margin="16,0">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="Preset" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="AdvPresetCombo" Width="220" Height="26"
                                  SelectionChanged="OnAdvPresetSelected"/>
                        <Button Content="Save" Style="{StaticResource SubtleButton}"
                                Click="OnAdvSavePreset" Height="26" FontSize="11" Padding="10,2" Margin="6,0,0,0"/>
                        <Button Content="Delete" Style="{StaticResource SubtleButton}"
                                Click="OnAdvDeletePreset" Height="26" FontSize="11" Padding="10,2" Margin="4,0,0,0"
                                Foreground="#aa6666"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="Reset Defaults" Style="{StaticResource SubtleButton}"
                                Click="OnAdvResetDefaults" Height="26" FontSize="11" Padding="10,2"/>
                        <Button Content="Export" Style="{StaticResource SubtleButton}"
                                Click="OnAdvExport" Height="26" FontSize="11" Padding="10,2" Margin="6,0,0,0"
                                Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"/>
                        <Button Content="Import" Style="{StaticResource SubtleButton}"
                                Click="OnAdvImport" Height="26" FontSize="11" Padding="10,2" Margin="6,0,0,0"
                                Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"/>
                        <Button Content="Import XML" Style="{StaticResource SubtleButton}"
                                Click="OnAdvImportXml" Height="26" FontSize="11" Padding="10,2" Margin="6,0,0,0"
                                ToolTip="Load values from a playercamerapreset.xml file"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Row 2: Search & filter -->
            <Border Grid.Row="1" Background="#1e1e1e">
                <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                    <Button Content="Expand All" Style="{StaticResource SubtleButton}"
                            Click="OnAdvExpandAll" Height="26" FontSize="11" Padding="10,2" Margin="0,0,8,0"/>
                    <TextBox x:Name="AdvSearchBox" Width="200" Height="26" FontSize="11"
                             Foreground="#e0e0e0" CaretBrush="#e0e0e0"
                             Background="#2e2e2e" BorderBrush="#333333" BorderThickness="1"
                             Padding="6,4" VerticalContentAlignment="Center"
                             Style="{x:Null}"
                             KeyUp="OnAdvSearchChanged"/>
                    <ComboBox x:Name="AdvFilterCombo" Width="160" Height="26" Margin="8,0,0,0"
                              SelectionChanged="OnAdvFilterChanged"/>
                    <TextBlock x:Name="AdvRowCountLabel" FontSize="10"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- DataGrid -->
            <DataGrid x:Name="AdvDataGrid" Grid.Row="2"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      CanUserReorderColumns="False" SelectionMode="Single" SelectionUnit="Cell"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#2a2a2a"
                      Background="{StaticResource BgDarkBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      RowBackground="{StaticResource BgDarkBrush}"
                      AlternatingRowBackground="#1e1e1e"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="0"
                      FontSize="11" RowHeight="26"
                      ColumnHeaderHeight="30"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.IsDeferredScrollingEnabled="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource BgPanelBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="BorderBrush" Value="#2a2a2a"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="6,2"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#30c8a24e"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsModified}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <Expander IsExpanded="False" Background="Transparent" BorderThickness="0">
                                                <Expander.Header>
                                                    <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}" Margin="4,2"/>
                                                </Expander.Header>
                                                <ItemsPresenter/>
                                            </Expander>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </DataGrid.GroupStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="SECTION" Binding="{Binding Section}" Width="220" IsReadOnly="True"/>
                    <DataGridTextColumn Header="SUB-ELEMENT" Binding="{Binding SubElement}" Width="150" IsReadOnly="True"/>
                    <DataGridTextColumn Header="ATTRIBUTE" Binding="{Binding Attribute}" Width="170" IsReadOnly="True"/>
                    <DataGridTextColumn Header="VALUE" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="120">
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="VANILLA" Binding="{Binding VanillaValue, Mode=OneWay}" Width="120" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- ═══ Separator ═══ -->
        <Border Grid.Row="4" Background="{StaticResource BorderBrush}"/>

        <!-- ═══ Bottom Bar ═══ -->
        <Border Grid.Row="5" Background="{StaticResource BgPanelBrush}">
            <DockPanel Margin="20,0">
                <TextBlock x:Name="StatusLabel" Text="Ready" FontSize="11"
                           Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>

                <!-- Simple mode buttons -->
                <StackPanel x:Name="SimpleButtons" Orientation="Horizontal" DockPanel.Dock="Right"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Content="Advanced" Style="{StaticResource SubtleButton}"
                            Click="OnToggleAdvanced" Width="110" Height="34" FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                    <Button x:Name="InstallBtn" Content="Install" Style="{StaticResource AccentButton}"
                            Click="OnInstall" Width="110" Height="34" FontSize="13"/>
                    <Button x:Name="RestoreBtn" Content="Restore Vanilla" Style="{StaticResource SubtleButton}"
                            Click="OnRestore" Width="130" Height="34" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Advanced mode buttons -->
                <StackPanel x:Name="AdvancedButtons" Orientation="Horizontal" DockPanel.Dock="Right"
                            VerticalAlignment="Center" HorizontalAlignment="Right" Visibility="Collapsed">
                    <Button Content="← Simple" Style="{StaticResource SubtleButton}"
                            Click="OnToggleAdvanced" Width="100" Height="34" FontSize="12" Margin="0,0,8,0"/>
                    <Button x:Name="AdvApplyBtn" Content="Apply to Game" Style="{StaticResource AccentButton}"
                            Click="OnAdvApply" Width="140" Height="34" FontSize="13"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
