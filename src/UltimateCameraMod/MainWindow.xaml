<Window x:Class="UltimateCameraMod.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:UltimateCameraMod.Controls"
        Title="Ultimate Camera Mod v2.5"
        Icon="icon.ico"
        Width="1060" Height="1000" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>  <!-- Title bar -->
            <RowDefinition Height="Auto"/> <!-- Alert banner -->
            <RowDefinition Height="1"/>   <!-- Separator -->
            <RowDefinition Height="*"/>   <!-- Body -->
            <RowDefinition Height="1"/>   <!-- Separator -->
            <RowDefinition Height="56"/>  <!-- Bottom bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Title Bar ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}">
            <DockPanel Margin="20,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="ULTIMATE CAMERA MOD" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="  v2.5  |  by 0xFitz" FontSize="10"
                               Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <Ellipse x:Name="VersionDot" Width="7" Height="7" Fill="#555" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="VersionStatus" Text="checking..." FontSize="9"
                               Foreground="#555" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <Button x:Name="VersionUpdateBtn" Visibility="Collapsed"
                            Style="{StaticResource SubtleButton}" FontSize="9" Padding="6,2" Height="20"
                            Foreground="#4CAF50" BorderBrush="#4CAF50" Margin="8,0,0,0"
                            Click="OnUpdateGitHubClick" Content="Get update"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Button Content="⬡  NexusMods" Style="{StaticResource SubtleButton}"
                            Foreground="#d98f40" Click="OnNexusClick" Margin="0,0,4,0"
                            BorderThickness="0" FontSize="10" Padding="8,4"/>
                    <Button Content="⚑  GitHub" Style="{StaticResource SubtleButton}"
                            Click="OnGitHubClick" BorderThickness="0" FontSize="10" Padding="8,4" Margin="0,0,4,0"/>
                    <Button Content="☕ Buy me a coffee" Style="{StaticResource SubtleButton}"
                            Click="OnKofiClick" BorderThickness="0" FontSize="10" Padding="8,4"
                            ToolTip="Opens Ko-fi — tips help keep UCM going"
                            Foreground="#FF5E5B"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ Game Path + Alert Banner ═══ -->
        <StackPanel Grid.Row="1">
            <Border Background="{StaticResource BgPanelBrush}" Padding="20,4">
                <DockPanel>
                    <Button Content="📂" DockPanel.Dock="Right" Style="{StaticResource SubtleButton}"
                            FontSize="12" Padding="6,2" Height="22" VerticalAlignment="Center"
                            Click="OnOpenGameFolder" ToolTip="Open game folder"
                            BorderThickness="0" Foreground="{StaticResource TextDimBrush}"/>
                    <TextBlock x:Name="GamePathLabel" FontFamily="Consolas" FontSize="9"
                               Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
            <Border x:Name="BannerPanel" Height="Auto" Visibility="Collapsed">
                <TextBlock x:Name="BannerText" FontSize="11" VerticalAlignment="Center" Margin="20,6"/>
            </Border>
        </StackPanel>

        <!-- ═══ Separator ═══ -->
        <Border Grid.Row="2" Background="{StaticResource BorderBrush}"/>

        <!-- ═══ Body: Simple Mode ═══ -->
        <Grid x:Name="SimpleView" Grid.Row="3" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520"/>
                <ColumnDefinition Width="440"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left Column: Controls ── -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,20,0">
                <StackPanel>
                    <!-- CAMERA STYLE section -->
                    <TextBlock Text="CAMERA STYLE" Style="{StaticResource SectionHeader}"/>

                    <!-- Tab bar -->
                    <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Margin="0,6,0,0" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="TabPresets" Content="Presets" Width="140" Height="32"
                                    Style="{StaticResource AccentButton}" Click="OnTabPresets" FontSize="12"/>
                            <Button x:Name="TabCustom" Content="Custom" Width="140" Height="32"
                                    Style="{StaticResource SubtleButton}" Click="OnTabCustom" FontSize="12"
                                    BorderThickness="0" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Tab content -->
                    <Border x:Name="PresetsBorder" Background="{StaticResource BgPanelBrush}" CornerRadius="6" Margin="0,4,0,0" Padding="16,14">
                        <!-- Presets tab -->
                        <StackPanel x:Name="PresetsPanel">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Camera style" Style="{StaticResource FieldLabel}" Grid.Column="0"/>
                                <ComboBox x:Name="StyleCombo" Grid.Column="1" Height="32"
                                          SelectionChanged="OnSettingChanged"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Custom tab (hidden by default) -->
                    <Border x:Name="CustomPanel" Background="{StaticResource BgPanelBrush}"
                            CornerRadius="6" Margin="0,4,0,0" Padding="16,14" Visibility="Collapsed">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Saved preset" Style="{StaticResource FieldLabel}" Grid.Row="0"/>
                                <ComboBox x:Name="PresetCombo" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                          Height="32" SelectionChanged="OnPresetSelected" Margin="0,0,0,8"/>

                                <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1"
                                        Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>

                                <TextBlock Text="Distance" Style="{StaticResource FieldLabel}" Grid.Row="2"/>
                                <Slider x:Name="DistSlider" Grid.Row="2" Grid.Column="1"
                                        Minimum="1.5" Maximum="12" Value="5" TickFrequency="0.1"
                                        IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                                <TextBlock x:Name="DistLabel" Grid.Row="2" Grid.Column="2"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Text="5.0"/>

                                <TextBlock Text="Height" Style="{StaticResource FieldLabel}" Grid.Row="3"/>
                                <Slider x:Name="HeightSlider" Grid.Row="3" Grid.Column="1"
                                        Minimum="-1.6" Maximum="0.5" Value="0" TickFrequency="0.1"
                                        IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                                <TextBlock x:Name="HeightLabel" Grid.Row="3" Grid.Column="2"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Text="0.0"/>

                                <TextBlock Text="Horizontal shift" Style="{StaticResource FieldLabel}" Grid.Row="4"/>
                                <Slider x:Name="HShiftSlider" Grid.Row="4" Grid.Column="1"
                                        Minimum="-3" Maximum="3" Value="0" TickFrequency="0.1"
                                        IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                                <TextBlock x:Name="HShiftLabel" Grid.Row="4" Grid.Column="2"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Text="0.0"/>

                                <TextBlock x:Name="HShiftTip" Grid.Row="5" Grid.ColumnSpan="3"
                                           FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                           Text="How far left/right the camera sits from the character. Centered camera locks this to 0."
                                           Margin="0,0,0,4"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Save preset" Style="{StaticResource SubtleButton}"
                                        Click="OnSavePreset" Width="100" Height="28" FontSize="11"/>
                                <Button Content="Delete preset" Style="{StaticResource SubtleButton}"
                                        Click="OnDeletePreset" Width="100" Height="28" FontSize="11"
                                        Foreground="#aa6666" Margin="4,0,0,0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="SHARE" FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <Button Content="Export string" Style="{StaticResource SubtleButton}"
                                        Click="OnExportString" Width="100" Height="28" FontSize="11"
                                        Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"/>
                                <Button Content="Import string" Style="{StaticResource SubtleButton}"
                                        Click="OnImportString" Width="100" Height="28" FontSize="11"
                                        Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"
                                        Margin="4,0,0,0"/>
                            </StackPanel>

                            <TextBlock FontSize="9" Foreground="{StaticResource TextDimBrush}" Margin="0,6,0,0"
                                       Text="Limits: Dist 1.5-12.0  |  Height -1.6 to 0.5  |  Shift -3.0 to 3.0"/>
                        </StackPanel>
                    </Border>

                    <!-- GLOBAL SETTINGS section -->
                    <TextBlock Text="GLOBAL SETTINGS" Style="{StaticResource SectionHeader}"/>
                    <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Margin="0,6,0,0" Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Field of view" Style="{StaticResource FieldLabel}" Grid.Row="0"/>
                            <ComboBox x:Name="FovCombo" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                      Height="32" SelectionChanged="OnSettingChanged" Margin="0,0,0,8"/>

                            <TextBlock Text="Combat camera" Style="{StaticResource FieldLabel}" Grid.Row="1"/>
                            <ComboBox x:Name="CombatCombo" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                      Height="32" SelectionChanged="OnSettingChanged" Margin="0,0,0,8"/>

                            <TextBlock Text="Centered camera" Style="{StaticResource FieldLabel}" Grid.Row="2"/>
                            <CheckBox x:Name="BaneCheck" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                      Content="Center character on screen (locks Horizontal Shift to 0)"
                                      Checked="OnBaneChanged" Unchecked="OnBaneChanged" Margin="0,0,0,8"/>

                            <TextBlock Text="Mount camera" Style="{StaticResource FieldLabel}" Grid.Row="3"/>
                            <CheckBox x:Name="MountHeightCheck" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                      Content="Match mount/horse height to player camera height"
                                      Checked="OnSettingChanged" Unchecked="OnSettingChanged" Margin="0,0,0,8"/>

                            <TextBlock Text="Steadycam" Style="{StaticResource FieldLabel}" Grid.Row="4"/>
                            <CheckBox x:Name="SteadycamCheck" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                                      Content="Smooth camera transitions (eliminates zoom jitter between states)"
                                      IsChecked="True" Margin="0,0,0,8"
                                      ToolTip="Smooths blending, damping and velocity offsets between movement states. Disable to restore vanilla camera transitions."/>

                        </Grid>
                    </Border>
                    <!-- Update notice -->
                    <Border Background="#1affc107" CornerRadius="4" Margin="0,14,0,0" Padding="10,8">
                        <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#b0b0b0">
                            <Run FontWeight="SemiBold" Foreground="#d98f40">Note:</Run>
                            <Run> Game updates will overwrite modded files. After each Crimson Desert update, re-run UCM Install to restore your camera settings.</Run>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ── Right Column: Previews ── -->
            <StackPanel Grid.Column="1">
                <TextBlock Text="CAMERA PREVIEW" Style="{StaticResource SectionHeader}"/>
                <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Margin="0,6,0,8" Padding="6">
                    <controls:CameraPreview x:Name="Preview"/>
                </Border>
                <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="6">
                    <StackPanel>
                        <controls:FovPreview x:Name="FovPreviewCtrl"/>
                        <TextBlock FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,4,0,0"
                                   HorizontalAlignment="Center"
                                   Text="Shift 0 = vanilla (char left)  |  0.5 = center  |  negative = more left  |  positive = more right"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ═══ Body: Advanced Controls ═══ -->
        <Grid x:Name="AdvancedControlsView" Grid.Row="3" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Left: scrollable sections -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Margin="16,12,6,12">
                <StackPanel x:Name="AdvCtrlPanel" HorizontalAlignment="Stretch">

                    <!-- Preset bar -->
                    <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="Preset" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="AdvCtrlPresetCombo" Width="200" Height="26"
                                          SelectionChanged="OnAdvCtrlPresetSelected"/>
                                <Button Content="Save" Style="{StaticResource SubtleButton}"
                                        Click="OnAdvCtrlSavePreset" Height="26" FontSize="11" Padding="10,2" Margin="6,0,0,0"/>
                                <Button Content="Delete" Style="{StaticResource SubtleButton}"
                                        Click="OnAdvCtrlDeletePreset" Height="26" FontSize="11" Padding="10,2" Margin="4,0,0,0"
                                        Foreground="#aa6666"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="Load from Simple" Style="{StaticResource SubtleButton}"
                                        Click="OnAdvCtrlLoadFromSimple" Height="26" FontSize="11" Padding="10,2"
                                        ToolTip="Populate all sliders from your current Simple mode settings"/>
                                <Button Content="Reset to Vanilla" Style="{StaticResource SubtleButton}"
                                        Click="OnAdvCtrlResetVanilla" Height="26" FontSize="11" Padding="10,2" Margin="6,0,0,0"
                                        Foreground="#aa6666" ToolTip="Reset all sliders to vanilla XML values"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Section A: On-Foot Zoom Levels -->
                    <Expander x:Name="AdvSectionA" IsExpanded="True" Margin="0,0,0,8">
                        <Expander.Header>
                            <TextBlock Text="A  —  On-Foot Zoom Levels" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <Border Background="{StaticResource BgPanelBrush}" CornerRadius="0,0,6,6" Padding="12,12,8,12">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,12" LineHeight="18">
                                    The game has 3 scroll-wheel zoom levels on foot. ZL2 is closest (default view), ZL3 is mid-range, ZL4 is furthest out.
                                    Each level independently controls camera distance, height, and horizontal position.
                                    These apply to all on-foot states: idle, walking, running, sprinting, and combat movement.
                                </TextBlock>
                                <Grid x:Name="AdvCtrlOnFootGrid"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- Section B: Horse / Mount Zoom Levels -->
                    <Expander x:Name="AdvSectionB" IsExpanded="False" Margin="0,0,0,8">
                        <Expander.Header>
                            <TextBlock Text="B  —  Horse / Mount Zoom Levels" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <Border Background="{StaticResource BgPanelBrush}" CornerRadius="0,0,6,6" Padding="12,12,8,12">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,12" LineHeight="18">
                                    Mounted cameras have 4 zoom levels (ZL0–ZL3). All 8 horse states are synchronized so the camera
                                    doesn't jolt during speed changes. ZL0 is the closest scroll-in level (or first-person if enabled).
                                </TextBlock>
                                <Grid x:Name="AdvCtrlMountGrid"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- Section C: Combat / Lock-On -->
                    <Expander x:Name="AdvSectionC" IsExpanded="False" Margin="0,0,0,8">
                        <Expander.Header>
                            <TextBlock Text="C  —  Combat / Lock-On" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <Border Background="{StaticResource BgPanelBrush}" CornerRadius="0,0,6,6" Padding="12,12,8,12">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,12" LineHeight="18">
                                    When you lock onto an enemy the camera switches to combat tracking mode.
                                    TargetRate controls how aggressively the camera follows the enemy — lower values give you more manual control.
                                    ScreenClampRate controls how centered the enemy stays on screen.
                                </TextBlock>
                                <Grid x:Name="AdvCtrlCombatGrid"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- Section D: Camera Smoothing / Steadycam -->
                    <Expander x:Name="AdvSectionD" IsExpanded="False" Margin="0,0,0,8">
                        <Expander.Header>
                            <TextBlock Text="D  —  Camera Smoothing / Steadycam" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <Border Background="{StaticResource BgPanelBrush}" CornerRadius="0,0,6,6" Padding="16,12">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,12" LineHeight="18">
                                    These control how the camera transitions between movement states.
                                    BlendInTime is how many seconds the camera takes to ease into a state.
                                    OffsetLength controls camera sway — setting it to 0 gives a steadycam feel with no sideways movement.
                                </TextBlock>
                                <Grid x:Name="AdvCtrlSmoothGrid"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- Section E: Aiming / Crosshair Position -->
                    <Expander x:Name="AdvSectionE" IsExpanded="False" Margin="0,0,0,8">
                        <Expander.Header>
                            <TextBlock Text="E  —  Aiming / Crosshair Position" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <Border Background="{StaticResource BgPanelBrush}" CornerRadius="0,0,6,6" Padding="16,12">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,12" LineHeight="18">
                                    When you aim with the lantern, bow, or weapon zoom the camera shifts to position the crosshair.
                                    These RightOffset values scale proportionally from your horizontal shift so the camera doesn't snap sideways when activating abilities.
                                </TextBlock>
                                <Grid x:Name="AdvCtrlAimGrid"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                </StackPanel>
            </ScrollViewer>

            <!-- Right: status / apply panel -->
            <Border Grid.Column="1" Background="{StaticResource BgPanelBrush}" Margin="0,12,20,12"
                    CornerRadius="6" Padding="14,14">
                <StackPanel>
                    <TextBlock Text="ADVANCED CONTROLS" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                               Margin="0,0,0,16" LineHeight="16">
                        Each slider shows the current value and the vanilla default (dimmed).
                        Click ↺ on any row to reset that parameter to vanilla.
                        Hit Apply to write all changes to the game.
                    </TextBlock>

                    <TextBlock x:Name="AdvCtrlChangedLabel" Text="0 changes" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>

                    <Button x:Name="AdvCtrlApplyBtn" Content="Apply to Game"
                            Style="{StaticResource AccentButton}" Click="OnAdvCtrlApply"
                            Height="36" FontSize="13" Margin="0,0,0,8"/>

                    <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                               LineHeight="16" Margin="0,8,0,0">
                        Changes are applied on top of vanilla XML — they do not interact with Simple mode presets.
                        Use "Load from Simple" to start from your current preset.
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ Body: Expert Mode (raw XML editor) ═══ -->
        <Grid x:Name="ExpertView" Grid.Row="3" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Row 1: Preset management -->
            <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}">
                <DockPanel Margin="16,0">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="Preset" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="AdvPresetCombo" Width="220" Height="26"
                                  SelectionChanged="OnAdvPresetSelected"/>
                        <Button Content="Save" Style="{StaticResource SubtleButton}"
                                Click="OnAdvSavePreset" Height="26" FontSize="11" Padding="10,2" Margin="6,0,0,0"/>
                        <Button Content="Delete" Style="{StaticResource SubtleButton}"
                                Click="OnAdvDeletePreset" Height="26" FontSize="11" Padding="10,2" Margin="4,0,0,0"
                                Foreground="#aa6666"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="Reset Defaults" Style="{StaticResource SubtleButton}"
                                Click="OnAdvResetDefaults" Height="26" FontSize="11" Padding="10,2"/>
                        <Button Content="Export" Style="{StaticResource SubtleButton}"
                                Click="OnAdvExport" Height="26" FontSize="11" Padding="10,2" Margin="6,0,0,0"
                                Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"/>
                        <Button Content="Import" Style="{StaticResource SubtleButton}"
                                Click="OnAdvImport" Height="26" FontSize="11" Padding="10,2" Margin="6,0,0,0"
                                Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"/>
                        <Button Content="Import XML" Style="{StaticResource SubtleButton}"
                                Click="OnAdvImportXml" Height="26" FontSize="11" Padding="10,2" Margin="6,0,0,0"
                                ToolTip="Load values from a playercamerapreset.xml file"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Row 2: Search & filter -->
            <Border Grid.Row="1" Background="#1e1e1e">
                <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                    <Button Content="Expand All" Style="{StaticResource SubtleButton}"
                            Click="OnAdvExpandAll" Height="26" FontSize="11" Padding="10,2" Margin="0,0,8,0"/>
                    <TextBox x:Name="AdvSearchBox" Width="200" Height="26" FontSize="11"
                             Foreground="#e0e0e0" CaretBrush="#e0e0e0"
                             Background="#2e2e2e" BorderBrush="#333333" BorderThickness="1"
                             Padding="6,4" VerticalContentAlignment="Center"
                             Style="{x:Null}"
                             KeyUp="OnAdvSearchChanged"/>
                    <ComboBox x:Name="AdvFilterCombo" Width="160" Height="26" Margin="8,0,0,0"
                              SelectionChanged="OnAdvFilterChanged"/>
                    <TextBlock x:Name="AdvRowCountLabel" FontSize="10"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- DataGrid -->
            <DataGrid x:Name="ExpertDataGrid" Grid.Row="2"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      CanUserReorderColumns="False" SelectionMode="Single" SelectionUnit="Cell"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#2a2a2a"
                      Background="{StaticResource BgDarkBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      RowBackground="{StaticResource BgDarkBrush}"
                      AlternatingRowBackground="#1e1e1e"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="0"
                      FontSize="11" RowHeight="26"
                      ColumnHeaderHeight="30"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.IsDeferredScrollingEnabled="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource BgPanelBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="BorderBrush" Value="#2a2a2a"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="6,2"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#30c8a24e"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsModified}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <Expander IsExpanded="False" Background="Transparent" BorderThickness="0">
                                                <Expander.Header>
                                                    <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}" Margin="4,2"/>
                                                </Expander.Header>
                                                <ItemsPresenter/>
                                            </Expander>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </DataGrid.GroupStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="SECTION" Binding="{Binding Section}" Width="220" IsReadOnly="True"/>
                    <DataGridTextColumn Header="SUB-ELEMENT" Binding="{Binding SubElement}" Width="150" IsReadOnly="True"/>
                    <DataGridTextColumn Header="ATTRIBUTE" Binding="{Binding Attribute}" Width="170" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="ToolTip" Value="{Binding AttributeDoc}"/>
                                <Setter Property="ToolTipService.ShowDuration" Value="12000"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="VALUE" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="120">
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="VANILLA" Binding="{Binding VanillaValue, Mode=OneWay}" Width="120" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- ═══ Body: JSON Mod Manager ═══ -->
        <ScrollViewer x:Name="JsonModManagerView" Grid.Row="3" Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto" Background="{StaticResource BgDarkBrush}"
                      TextElement.Foreground="{StaticResource TextPrimaryBrush}">
            <StackPanel Margin="28,20,28,20" MaxWidth="760">

                <!-- How it works banner -->
                <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="16,14" Margin="0,0,0,16"
                        BorderBrush="#333" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="HOW IT WORKS" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                   LineHeight="20" Margin="0,0,0,8">
                            This tab generates a <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">.json patch file</Run>
                            compatible with <Run FontWeight="SemiBold">Crimson Desert JSON Mod Manager v8</Run>.
                            Drop the file into the mod manager's <Run FontFamily="Consolas">Mods/</Run> folder and your camera settings
                            will appear as a toggleable mod — no UCM required.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="18">
                            The patch works by comparing your modified camera file against the vanilla file byte-by-byte
                            and recording only the differences. This means it's game-version specific — if the game updates,
                            regenerate the patch.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Step 1: Mod Info -->
                <TextBlock Text="STEP 1  —  NAME YOUR MOD" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="16,14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="This info appears inside the mod manager so people know what the mod is."
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <!-- Title -->
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Title" Width="90" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="JsonTitleBox" Text="UCM Camera Config" FontSize="12"/>
                        </DockPanel>
                        <!-- Version + Author -->
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Version" Width="90" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="Author" Width="60" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       DockPanel.Dock="Right" Margin="12,0,0,0"/>
                            <TextBox x:Name="JsonAuthorBox" Width="200" DockPanel.Dock="Right" FontSize="12"/>
                            <TextBox x:Name="JsonVersionBox" FontSize="12"/>
                        </DockPanel>
                        <!-- Nexus URL -->
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Nexus URL" Width="90" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="JsonNexusBox"
                                     Text="https://www.nexusmods.com/crimsondesert/mods/438" FontSize="12"/>
                        </DockPanel>
                        <!-- Description -->
                        <DockPanel>
                            <TextBlock Text="Description" Width="90" VerticalAlignment="Top"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0"/>
                            <TextBox x:Name="JsonDescBox" Height="70" FontSize="12"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Step 2: Generate -->
                <TextBlock Text="STEP 2  —  GENERATE THE PATCH" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                <Border Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="16,14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,12" LineHeight="18">
                            Choose what settings to patch from. <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Current Settings</Run>
                            uses whatever is active in Simple mode right now.
                            <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">From XML File</Run>
                            lets you pick any exported <Run FontFamily="Consolas">playercamerapreset.xml</Run> to patch from instead.
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Generate from Current Settings" Style="{StaticResource AccentButton}"
                                    Click="OnJsonGenerate" Height="34" FontSize="12" Padding="14,0"
                                    ToolTip="Uses whatever is currently configured in Simple mode"/>
                            <Button Content="Generate from XML File..." Style="{StaticResource SubtleButton}"
                                    Click="OnJsonGenerateFromXml" Height="34" FontSize="11" Padding="12,0" Margin="8,0,0,0"
                                    ToolTip="Pick a playercamerapreset.xml file to diff against vanilla"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Step 3: Save (shown after generate) -->
                <Border x:Name="JsonPreviewPanel" Visibility="Collapsed"
                        Background="{StaticResource BgPanelBrush}" CornerRadius="6" Padding="16,14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="STEP 3  —  SAVE THE FILE" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#1a1a1a" CornerRadius="4" Padding="12,6" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="JsonPatchCountLabel" Text="0" FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text=" patch regions" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="4,0,0,5"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#1a1a1a" CornerRadius="4" Padding="12,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="JsonBytesChangedLabel" Text="0" FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text=" bytes changed" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="4,0,0,5"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,12" LineHeight="18">
                            Save the <Run FontFamily="Consolas">.json</Run> file, then drop it into the
                            <Run FontFamily="Consolas">Mods/</Run> folder inside your Crimson Desert JSON Mod Manager installation.
                            It will appear as a toggleable mod.
                        </TextBlock>
                        <Button Content="Save .json..." Style="{StaticResource AccentButton}"
                                Click="OnJsonSave" Height="34" FontSize="12" Padding="14,0"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ Separator ═══ -->
        <Border Grid.Row="4" Background="{StaticResource BorderBrush}"/>

        <!-- ═══ Bottom Bar ═══ -->
        <Border Grid.Row="5" Background="{StaticResource BgPanelBrush}">
            <DockPanel Margin="20,0">
                <TextBlock x:Name="StatusLabel" Text="Ready" FontSize="11"
                           Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>

                <!-- Mode selector (always visible) -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            VerticalAlignment="Center" HorizontalAlignment="Right">

                    <!-- Mode navigation buttons -->
                    <Border Background="#1a1a1a" CornerRadius="4" Padding="3" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ModeSimpleBtn" Content="Simple" Width="86" Height="30" FontSize="11"
                                    Style="{StaticResource AccentButton}" Click="OnModeSimple"/>
                            <Button x:Name="ModeAdvancedBtn" Content="Advanced" Width="96" Height="30" FontSize="11"
                                    Style="{StaticResource SubtleButton}" Click="OnModeAdvanced"
                                    BorderThickness="0" Margin="3,0,0,0"/>
                            <Button x:Name="ModeExpertBtn" Content="Expert" Width="80" Height="30" FontSize="11"
                                    Style="{StaticResource SubtleButton}" Click="OnModeExpert"
                                    BorderThickness="0" Margin="3,0,0,0"/>
                            <Button x:Name="ModeJsonBtn" Content="JSON Mod Mgr" Width="118" Height="30" FontSize="11"
                                    Style="{StaticResource SubtleButton}" Click="OnModeJson"
                                    BorderThickness="0" Margin="3,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Per-mode action buttons -->
                    <StackPanel x:Name="SimpleButtons" Orientation="Horizontal">
                        <Button Content="Export XML" Style="{StaticResource SubtleButton}"
                                Click="OnExportXmlFile" Height="34" FontSize="11" Padding="10,2" Margin="0,0,4,0"
                                Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"
                                ToolTip="Save the current live camera XML to a file"/>
                        <Button Content="Import XML" Style="{StaticResource SubtleButton}"
                                Click="OnImportXmlFile" Height="34" FontSize="11" Padding="10,2" Margin="0,0,4,0"
                                Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"
                                ToolTip="Install a camera XML file directly to the game"/>
                        <Button x:Name="InstallBtn" Content="Install" Style="{StaticResource AccentButton}"
                                Click="OnInstall" Width="110" Height="34" FontSize="13"/>
                        <Button x:Name="RestoreBtn" Content="Restore Vanilla" Style="{StaticResource SubtleButton}"
                                Click="OnRestore" Width="130" Height="34" Margin="4,0,0,0"/>
                    </StackPanel>

                    <StackPanel x:Name="AdvancedControlsButtons" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Content="Export XML" Style="{StaticResource SubtleButton}"
                                Click="OnExportXmlFile" Height="34" FontSize="11" Padding="10,2" Margin="0,0,4,0"
                                Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"
                                ToolTip="Save the current live camera XML to a file"/>
                        <Button Content="Import XML" Style="{StaticResource SubtleButton}"
                                Click="OnImportXmlFile" Height="34" FontSize="11" Padding="10,2" Margin="0,0,4,0"
                                Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"
                                ToolTip="Install a camera XML file directly to the game"/>
                        <Button x:Name="AdvCtrlApplyBtnBar" Content="Apply to Game" Style="{StaticResource AccentButton}"
                                Click="OnAdvCtrlApply" Width="140" Height="34" FontSize="13"/>
                    </StackPanel>

                    <StackPanel x:Name="ExpertButtons" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Content="Export XML" Style="{StaticResource SubtleButton}"
                                Click="OnExportXmlFile" Height="34" FontSize="11" Padding="10,2" Margin="0,0,4,0"
                                Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"
                                ToolTip="Save the current live camera XML to a file"/>
                        <Button Content="Import XML" Style="{StaticResource SubtleButton}"
                                Click="OnImportXmlFile" Height="34" FontSize="11" Padding="10,2" Margin="0,0,4,0"
                                Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"
                                ToolTip="Install a camera XML file directly to the game"/>
                        <Button x:Name="ExpertApplyBtn" Content="Apply to Game" Style="{StaticResource AccentButton}"
                                Click="OnAdvApply" Width="140" Height="34" FontSize="13"/>
                    </StackPanel>

                    <StackPanel x:Name="JsonModManagerButtons" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Content="Export XML" Style="{StaticResource SubtleButton}"
                                Click="OnExportXmlFile" Height="34" FontSize="11" Padding="10,2" Margin="0,0,4,0"
                                Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"
                                ToolTip="Save the current live camera XML to a file"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
