<Window x:Class="UltimateCameraMod.Avalonia.InputDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Width="460" Height="240" CanResize="False"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource BgDarkBrush}">
    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Grid.Row="0" FontSize="15" Foreground="{DynamicResource TextPrimaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,12"/>

        <TextBox x:Name="InputBox" Grid.Row="1" FontSize="20"
                 Background="{DynamicResource BgInputBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 Padding="12,10" VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Classes="subtle" Width="90" Height="36"
                    Click="OnCancel"/>
            <Button Content="OK" Classes="accent" Width="90" Height="36"
                    Click="OnOk" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
