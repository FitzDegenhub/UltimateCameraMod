<Window x:Class="UltimateCameraMod.Avalonia.ImportPresetDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Preset" Width="500" Height="660" CanResize="False"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource BgDarkBrush}">
    <StackPanel Margin="24">
        <TextBlock Text="Choose an import source" FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>

        <Button Content="Mod Manager Package (folder)" Classes="accent"
                Height="38" FontSize="12" Click="OnImportModPackage" Margin="0,0,0,8"
                ToolTip.Tip="Select a folder containing manifest.json -- imports name, author, and camera XML automatically"/>

        <Button Content="Camera XML File (.xml)" Classes="subtle"
                Height="38" FontSize="12" Click="OnImportXml" Margin="0,0,0,8"
                ToolTip.Tip="Select a playercamerapreset.xml file directly"/>

        <Button Content="PAZ Archive (.paz)" Classes="subtle"
                Height="38" FontSize="12" Click="OnImportPaz" Margin="0,0,0,8"
                ToolTip.Tip="Select a 0.paz file -- UCM will extract the camera XML from it"/>

        <Button Content="UCM Preset (.ucmpreset)" Classes="subtle"
                Height="38" FontSize="12" Click="OnImportUcmPreset" Margin="0,0,0,8"
                ToolTip.Tip="Import a .ucmpreset file shared by another UCM user"/>

        <TextBlock Text="Imports are saved in the import_presets folder next to this app and listed under Imported in the sidebar."
                   FontSize="10" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap"
                   Margin="0,12,0,0"/>

        <Button Content="Cancel" Classes="subtle"
                Height="32" FontSize="11" Width="90" HorizontalAlignment="Right"
                Click="OnCancel" Margin="0,12,0,0"/>
    </StackPanel>
</Window>
