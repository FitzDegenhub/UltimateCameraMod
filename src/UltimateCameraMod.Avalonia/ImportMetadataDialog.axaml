<UserControl x:Class="UltimateCameraMod.Avalonia.ImportMetadataDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="500">
    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="750">
    <StackPanel Margin="0,0,4,0">
        <TextBlock Text="Preset details" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
        <TextBlock x:Name="SourceHintLabel" FontSize="11"
                   Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap"
                   Margin="0,0,0,20"/>

        <TextBlock Text="Name *" FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
        <TextBox x:Name="NameBox" MinHeight="54" FontSize="18"
                 Background="#303030" Foreground="White" CaretBrush="White"
                 BorderBrush="#555555" BorderThickness="1"
                 Padding="12,14" VerticalContentAlignment="Center"
                 Margin="0,0,0,16"/>

        <TextBlock Text="Author (optional)" FontSize="12"
                   Foreground="{DynamicResource TextDimBrush}" Margin="0,0,0,6"/>
        <TextBox x:Name="AuthorBox" MinHeight="54" FontSize="18"
                 Background="#303030" Foreground="White" CaretBrush="White"
                 BorderBrush="#555555" BorderThickness="1"
                 Padding="12,14" VerticalContentAlignment="Center"
                 Margin="0,0,0,16"/>

        <TextBlock Text="Description (optional)" FontSize="12"
                   Foreground="{DynamicResource TextDimBrush}" Margin="0,0,0,6"/>
        <TextBox x:Name="DescriptionBox" MinHeight="100" FontSize="16"
                 Background="#303030" Foreground="White" CaretBrush="White"
                 BorderBrush="#555555" BorderThickness="1"
                 Padding="12,12" TextWrapping="Wrap" AcceptsReturn="True"
                 Margin="0,0,0,16"/>

        <TextBlock Text="URL -- Nexus / GitHub / etc. (optional)" FontSize="12"
                   Foreground="{DynamicResource TextDimBrush}" Margin="0,0,0,6"/>
        <TextBox x:Name="UrlBox" MinHeight="54" FontSize="18"
                 Background="#303030" Foreground="White" CaretBrush="White"
                 BorderBrush="#555555" BorderThickness="1"
                 Padding="12,14" VerticalContentAlignment="Center"
                 Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,4">
            <Button Content="Cancel" Classes="subtle"
                    Height="36" FontSize="12" Width="90"
                    Click="OnCancel"/>
            <Button Content="Import" Classes="accent"
                    Height="36" FontSize="13" Width="110"
                    Click="OnConfirmImport" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
    </ScrollViewer>
</UserControl>
